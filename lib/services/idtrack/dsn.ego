@endpoint "GET /services/idtrack/dsn"

import (
    "http"
    "sql"
)

func handler(req http.Request, w http.ResponseWriter ) {    
    try {
        db, err := sql.Open("dsn", "idtrack")
        if err == nil {
            db.Close()
            w.WriteHeader(http.StatusOK)

            return
        }
        
        w.Write(err.Error())
    }

    w.WriteHeader(http.StatusNotFound)
}
