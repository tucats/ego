// Test fixture (see tests/server/unittest.ego) exercising rest.Client.Delete()
// against the server, including its optional body parameter. Echoes the
// request back as a JSON object so a test can assert on exactly what the
// server received.

@endpoint delete path="/services/unit-test/echo"

import "http"

func handler(req http.Request, w *http.ResponseWriter) {
    result := {
        method:     req.Method,
        path:       req.URL.Path,
        parameters: req.Parameters,
        headers:    req.Headers,
        body:       req.Body,
    }

    w.Header().Add("Content-Type", "application/json")
    w.WriteHeader(http.StatusOK)
    w.WriteJSON(result)
}
