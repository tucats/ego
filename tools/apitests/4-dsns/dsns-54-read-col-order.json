{
    "description": "read rows with specific column order",
    "request": {
        "method": "GET",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/tables/ages/rows",
        "parameters": {
            "columns": "name,age",
            "sort":"name"
        },
        "headers": {
            "Content-Type": ["application/json"],
            "Accept": ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        }
    },
    "response": {
        "status": 200,
        "headers": {
            "Content-Type": ["application/vnd.ego.rows+json"]
        }
    },
    "tests": [
        {
            "name": "api version",
            "query": "server.api",
            "value": "1"
        },
        {
            "name": "server id",
            "query": "server.id",
            "value": "{{SERVER_ID}}"
        },
        {
            "name": "rows count: 4",
            "query": "count",
            "value": "4"
        },
        {
            "name": "column list 0 name",
            "query": "columns.0",
            "value": "name"
        },
        {
            "name": "column list 1 age",
            "query": "columns.1",
            "value": "age"
        },        {
            "name": "row 0 name: Sue",
            "query": "rows.0.name",
            "value": "Debbie"
        },
        {
            "name": "row 1 name",
            "query": "rows.1.name",
            "value": "Lisa"
        },
        {
            "name": "row 2 name",
            "query": "rows.2.name",
            "value": "Mary"
        },
        {
            "name": "row 3 name",
            "query": "rows.3.name",
            "value": "Sue"
        }
    ]
}