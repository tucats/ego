{
    "description": "begin a transaction on the DSN and save the transaction id",
    "request": {
        "method": "GET",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/begin",
        "headers": {
            "Accept": ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        }
    },
    "response": {
        "status": 200,
        "headers": {
            "Content-Type": ["transaction.response+json"]
        },
        "save": {
            "TX_ID": "id"
        }
    },
    "tests": [
        {
            "name": "api version",
            "query": "server.api",
            "value": "1"
        },
        {
            "name": "server id",
            "query": "server.id",
            "value": "{{SERVER_ID}}"
        },
        {
            "name": "transaction id is present",
            "query": "id",
            "op": "exists"
        },
        {
            "name": "expiration is present",
            "query": "expires",
            "op": "exists"
        }
    ]
}
