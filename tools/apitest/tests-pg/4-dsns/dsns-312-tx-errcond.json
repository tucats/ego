{
    "description": "user-defined error condition triggers rollback when delete matches zero rows",
    "request": {
        "method": "POST",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/tables/@transaction",
        "headers": {
            "Content-Type": ["application/json"],
            "Accept": ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        },
        "body": [
            {
                "operation": "delete",
                "table": "tx{{SQLUUID}}",
                "filters": ["EQ(id, 9999)"],
                "errors": [
                    {
                        "condition": "EQ(_rows_, 0)",
                        "status": 409,
                        "msg": "Expected row not found; transaction aborted"
                    }
                ]
            }
        ]
    },
    "response": {
        "status": 409,
        "headers": {
            "Content-Type": ["error+json"]
        }
    },
    "tests": [
        {
            "name": "api version",
            "query": "server.api",
            "value": "1"
        },
        {
            "name": "custom error message returned",
            "query": "msg",
            "value": "Expected row not found; transaction aborted"
        }
    ]
}
