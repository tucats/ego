{
    "description": "sql opcode with SELECT is promoted to readrows; returns rows+json with all rows",
    "request": {
        "method": "POST",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/tables/@transaction",
        "headers": {
            "Content-Type": ["application/json"],
            "Accept": ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        },
        "body": [
            {
                "operation": "sql",
                "sql": "SELECT id, name, score FROM tx{{SQLUUID}}"
            }
        ]
    },
    "response": {
        "status": 200,
        "headers": {
            "Content-Type": ["rows+json"]
        }
    },
    "tests": [
        {
            "name": "api version",
            "query": "server.api",
            "value": "1"
        },
        {
            "name": "server id",
            "query": "server.id",
            "value": "{{SERVER_ID}}"
        },
        {
            "name": "row count: 3",
            "query": "count",
            "value": "3"
        }
    ]
}
