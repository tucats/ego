{
    "description": "create dedicated test table for @transaction tests via sql opcode",
    "request": {
        "method": "POST",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/tables/@transaction",
        "headers": {
            "Content-Type": ["application/json"],
            "Accept": ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        },
        "body": [
            {
                "operation": "sql",
                "sql": "CREATE TABLE tx{{SQLUUID}} (id INTEGER NOT NULL, name TEXT NOT NULL, score INTEGER)"
            }
        ]
    },
    "response": {
        "status": 200,
        "headers": {
            "Content-Type": ["rowcount+json"]
        }
    },
    "tests": [
        {
            "name": "api version",
            "query": "server.api",
            "value": "1"
        },
        {
            "name": "server id",
            "query": "server.id",
            "value": "{{SERVER_ID}}"
        },
        {
            "name": "affected rows: 0",
            "query": "count",
            "value": "0"
        }
    ]
}
