{
    "description": "empty task list returns success",
    "request": {
        "method": "POST",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/tables/@transaction",
        "headers": {
            "Content-Type": ["application/json"],
            "Accept": ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        },
        "body": [ ]
    },
    "response": {
        "status": 200,
        "headers": {
            "Content-Type": ["rowcount+json"]
        }
    },
    "tests": [
        {
            "name": "api version",
            "query": "server.api",
            "value": "1"
        },
        {
            "name": "server id",
            "query": "server.id",
            "value": "{{SERVER_ID}}"
        },
        {
            "name": "zero row count",
            "query": "count",
            "value": "0"
        },        {
            "name": "msg string",
            "query": "msg",
            "value": "No tasks in transaction"
        }
    ]
}
