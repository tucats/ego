{
    "description": "UPDATE a row then SELECT to verify the change via @sql endpoint",
    "request": {
        "method": "PUT",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/tables/@sql",
        "headers": {
            "Content-Type": ["application/json"],
            "Accept": ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        },
        "body": [
            "UPDATE t{{SQLUUID}} SET note = 'senior' WHERE id = 1",
            "SELECT id, name, note FROM t{{SQLUUID}} WHERE id = 1"
        ]
    },
    "response": {
        "status": 200,
        "headers": {
            "Content-Type": ["rows+json"]
        }
    },
    "tests": [
        {
            "name": "api version",
            "query": "server.api",
            "value": "1"
        },
        {
            "name": "server id",
            "query": "server.id",
            "value": "{{SERVER_ID}}"
        },
        {
            "name": "rows count",
            "query": "count",
            "value": "1"
        },
        {
            "name": "row 0 id",
            "query": "rows.0.id",
            "value": "1"
        },
        {
            "name": "row 0 name",
            "query": "rows.0.name",
            "value": "Alice"
        },
        {
            "name": "row 0 note updated",
            "query": "rows.0.note",
            "value": "senior"
        }
    ]
}
