{
    "description": "drop events table (date/time test cleanup)",
    "request": {
        "method": "DELETE",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/tables/events",
        "headers": {
            "Content-Type": ["application/json"],
            "Accept":        ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        }
    },
    "response": {
        "status": 200,
        "headers": {
            "Content-Type": ["rowcount+json"]
        }
    },
    "tests": [
