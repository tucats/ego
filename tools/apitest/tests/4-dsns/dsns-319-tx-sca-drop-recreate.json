{
    "description": "drop sca table and recreate it with an extra column; insert a row with all three columns",
    "request": {
        "method": "POST",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/tables/@transaction",
        "headers": {
            "Content-Type": ["application/json"],
            "Accept": ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        },
        "body": [
            {
                "operation": "drop",
                "table": "sca{{SQLUUID}}"
            },
            {
                "operation": "sql",
                "sql": "CREATE TABLE sca{{SQLUUID}} (id INTEGER NOT NULL, name TEXT NOT NULL, extra TEXT)"
            },
            {
                "operation": "insert",
                "table": "sca{{SQLUUID}}",
                "data": {
                    "id": 2,
                    "name": "after",
                    "extra": "bonus"
                }
            }
        ]
    },
    "response": {
        "status": 200,
        "headers": {
            "Content-Type": ["rowcount+json"]
        }
    },
    "tests": [
        {
            "name": "api version",
            "query": "server.api",
            "value": "1"
        },
        {
            "name": "server id",
            "query": "server.id",
            "value": "{{SERVER_ID}}"
        },
        {
            "name": "affected rows: 1",
            "query": "count",
            "value": "1"
        }
    ]
}
