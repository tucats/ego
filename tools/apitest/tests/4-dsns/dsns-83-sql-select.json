{
    "description": "insert fifth row then SELECT all via @sql; verifies SELECT as last statement returns rows+json",
    "request": {
        "method": "PUT",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/tables/@sql",
        "headers": {
            "Content-Type": ["application/json"],
            "Accept": ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        },
        "body": [
            "// This is a comment and should be ignored. Blank lines are ignored also.",
            "",
            "INSERT INTO t{{SQLUUID}} (id, name, score, active, note) VALUES (5, 'Eve', 78.5, 1, 'member')",
            "SELECT id, name, active FROM t{{SQLUUID}} ORDER BY id"
        ]
    },
    "response": {
        "status": 200,
        "headers": {
            "Content-Type": ["rows+json"]
        }
    },
    "tests": [
        {
            "name": "api version",
            "query": "server.api",
            "value": "1"
        },
        {
            "name": "server id",
            "query": "server.id",
            "value": "{{SERVER_ID}}"
        },
        {
            "name": "rows count",
            "query": "count",
            "value": "5"
        },
        {
            "name": "row 0 id",
            "query": "rows.0.id",
            "value": "1"
        },
        {
            "name": "row 0 name",
            "query": "rows.0.name",
            "value": "Alice"
        },
        {
            "name": "row 0 active",
            "query": "rows.0.active",
            "value": "1"
        },
        {
            "name": "row 1 id",
            "query": "rows.1.id",
            "value": "2"
        },
        {
            "name": "row 1 name",
            "query": "rows.1.name",
            "value": "Bob"
        },
        {
            "name": "row 2 id",
            "query": "rows.2.id",
            "value": "3"
        },
        {
            "name": "row 2 name",
            "query": "rows.2.name",
            "value": "Carol"
        },
        {
            "name": "row 2 active",
            "query": "rows.2.active",
            "value": "0"
        },
        {
            "name": "row 3 id",
            "query": "rows.3.id",
            "value": "4"
        },
        {
            "name": "row 3 name",
            "query": "rows.3.name",
            "value": "Dave"
        },
        {
            "name": "row 4 id",
            "query": "rows.4.id",
            "value": "5"
        },
        {
            "name": "row 4 name",
            "query": "rows.4.name",
            "value": "Eve"
        }
    ]
}
