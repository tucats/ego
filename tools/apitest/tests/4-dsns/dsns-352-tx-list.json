{
    "description": "list all rows in the transaction-test table using the active transaction",
    "request": {
        "method": "GET",
        "endpoint": "/dsns/dsn-{{DSNUUID}}/tables/ttx{{SQLUUID}}/rows",
        "parameters": {
            "transaction": "{{TX_ID}}",
            "sort": "id"
        },
        "headers": {
            "Accept": ["*/*"],
            "Authorization": ["Bearer {{API_TOKEN}}"]
        }
    },
    "response": {
        "status": 200,
        "headers": {
            "Content-Type": ["rows+json"]
        }
    },
    "tests": [
        {
            "name": "api version",
            "query": "server.api",
            "value": "1"
        },
        {
            "name": "server id",
            "query": "server.id",
            "value": "{{SERVER_ID}}"
        },
        {
            "name": "row count is 3",
            "query": "count",
            "value": "3"
        },
        {
            "name": "row 0 id is 1",
            "query": "rows.0.id",
            "value": "1"
        },
        {
            "name": "row 0 name is Alice",
            "query": "rows.0.name",
            "value": "Alice"
        },
        {
            "name": "row 1 id is 2",
            "query": "rows.1.id",
            "value": "2"
        },
        {
            "name": "row 1 name is Bob",
            "query": "rows.1.name",
            "value": "Bob"
        },
        {
            "name": "row 2 id is 3",
            "query": "rows.2.id",
            "value": "3"
        },
        {
            "name": "row 2 name is Carol",
            "query": "rows.2.name",
            "value": "Carol"
        }
    ]
}
