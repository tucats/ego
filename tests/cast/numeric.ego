@test "cast: integer widening (smaller to larger)"

{
    // byte → wider signed integers; int() normalizes for strict-mode comparison.
    @assert int(int(byte(42)))    == 42
    @assert int(int32(byte(42)))  == 42
    @assert int(int64(byte(42)))  == 42

    // int8 → wider types (positive and negative)
    @assert int(int(int8(100)))     == 100
    @assert int(int32(int8(100)))   == 100
    @assert int(int64(int8(100)))   == 100
    @assert int(int(int8(-5)))      == -5
    @assert int(int32(int8(-5)))    == -5
    @assert int(int64(int8(-5)))    == -5

    // int16 → wider types
    @assert int(int(int16(1000)))   == 1000
    @assert int(int32(int16(1000))) == 1000
    @assert int(int64(int16(1000))) == 1000
    @assert int(int(int16(-300)))   == -300
    @assert int(int64(int16(-300))) == -300

    // int32 → int and int64
    @assert int(int(int32(100000)))   == 100000
    @assert int(int64(int32(100000))) == 100000
    @assert int(int(int32(-99999)))   == -99999
    @assert int(int64(int32(-99999))) == -99999

    // int → int64
    @assert int(int64(int(999)))   == 999
    @assert int(int64(int(-999)))  == -999
}

@test "cast: integer narrowing"

{
    // int64 → narrower types, no overflow; int() normalizes for comparison.
    @assert int(int32(int64(42)))   == 42
    @assert int(int(int64(42)))     == 42
    @assert int(int16(int64(100)))  == 100
    @assert int(int8(int64(42)))    == 42
    @assert int(byte(int64(200)))   == 200

    // int → narrower types
    @assert int(int32(100000))  == 100000
    @assert int(int16(1000))    == 1000
    @assert int(int8(42))       == 42
    @assert int(byte(255))      == 255
    @assert int(byte(0))        == 0

    // Negative values into signed narrower types
    @assert int(int32(-100000))  == -100000
    @assert int(int16(-1000))    == -1000
    @assert int(int8(-42))       == -42
}

@test "cast: unsigned integer types"

{
    @assert typeof(uint16(42))   == uint16
    @assert typeof(uint32(42))   == uint32
    @assert typeof(uint64(42))   == uint64

    @assert int(uint16(1000))    == 1000
    @assert int(uint32(100000))  == 100000
    @assert int(uint64(1000000)) == 1000000

    // Zero values
    @assert int(uint16(0)) == 0
    @assert int(uint32(0)) == 0
    @assert int(uint64(0)) == 0

    // Unsigned from int32 and int64
    @assert int(uint16(int32(42)))   == 42
    @assert int(uint32(int64(42)))   == 42
    @assert int(uint64(int64(9999))) == 9999
}

@test "cast: integer type identity"

{
    // Each cast produces the declared type.
    @assert typeof(byte(1))    == byte
    @assert typeof(int8(1))    == int8
    @assert typeof(int16(1))   == int16
    @assert typeof(int32(1))   == int32
    @assert typeof(int64(1))   == int64
    @assert typeof(int(1))     == int
    @assert typeof(uint16(1))  == uint16
    @assert typeof(uint32(1))  == uint32
    @assert typeof(uint64(1))  == uint64
}

@test "cast: float widening (float32 to float64)"

{
    func near(a, b float64) bool {
        return math.Abs(a-b) < 1e-6
    }

    @assert near(float64(float32(1.0)),   1.0)
    @assert near(float64(float32(0.0)),   0.0)
    @assert near(float64(float32(-1.5)), -1.5)
    @assert near(float64(float32(100.0)), 100.0)

    @assert typeof(float64(float32(1.0))) == float64
}

@test "cast: float narrowing (float64 to float32)"

{
    @assert typeof(float32(1.0))    == float32
    @assert typeof(float32(-2.5))   == float32
    @assert typeof(float32(0.0))    == float32

    // Round-trip: cast to float32 and back preserves value within float32 precision.
    func near(a, b float64) bool {
        return math.Abs(a-b) < 1e-5
    }
    @assert near(float64(float32(1.0)),  1.0)
    @assert near(float64(float32(-2.5)), -2.5)
}

@test "cast: integer to float"

{
    func near(a, b float64) bool {
        return math.Abs(a-b) < 1e-9
    }

    @assert float64(0)    == 0.0
    @assert float64(1)    == 1.0
    @assert float64(-5)   == -5.0
    @assert float64(100)  == 100.0

    @assert near(float64(int32(42)),    42.0)
    @assert near(float64(int64(9999)), 9999.0)
    @assert near(float64(int8(-7)),     -7.0)
    @assert near(float64(byte(255)),   255.0)

    @assert typeof(float64(5))  == float64
    @assert typeof(float32(5))  == float32
    @assert typeof(float64(-1)) == float64
}

@test "cast: float to integer (truncation toward zero)"

{
    // Positive values: fractional part is discarded.
    @assert int(3.9)    == 3
    @assert int(3.1)    == 3
    @assert int(3.0)    == 3
    @assert int(int32(5.7))  == 5
    @assert int(int8(2))     == 2

    // Negative values: truncation is toward zero, not toward negative infinity.
    @assert int(-3.9)    == -3
    @assert int(-3.1)    == -3
    @assert int(int32(-5.0)) == -5

    @assert int(-7.9)  == -7

    // Zero
    @assert int(0.0)         == 0
    @assert int(int32(0.0))  == 0

    @assert typeof(int(1.5))    == int
    @assert typeof(int32(2.0))  == int32
}
