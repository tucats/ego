// Tests for Ego-specific features of the strings packages

@test "strings: strings.Split(), optional separator"
{
    a := strings.Split("first\nsecond\nthird")
    @assert len(a) == 3
    @assert a[0] == "first"
    @assert a[1] == "second"
    @assert a[2] == "third"
}

@test "strings: strings.Split, explicit newline separator"
{
    a := strings.Split("first\nsecond\nthird", "\n")
    @assert len(a) == 3
    @assert a[0] == "first"
    @assert a[1] == "second"
    @assert a[2] == "third"

}


@test "packages: strings.Split, explicit empty separator"
{
    a := strings.Split("first", "")
    @assert len(a) == 5
    @assert a[0] == "f"
    @assert a[1] == "i"
    @assert a[2] == "r"
    @assert a[3] == "s"
    @assert a[4] == "t"
}



@test "packages: strings.Split, empty string, text sep"
{
    a := strings.Split("", "B")
    @assert len(a) == 1
    @assert a[0] == ""
}


@test "packages: strings.Split, empty string, no sep"
{
    a := strings.Split("")
    @assert len(a) == 1
    @assert a[0] == ""
}



@test "packages: strings.Split, empty string, empty sep"
{
    a := strings.Split("", "")
    @assert len(a) == 0
}

@test "packages: strings.String, multiple int values"
{
    a := strings.String(65, 66, 67)
    @assert a == "ABC"
}

@test "packages: strings.String, multiple int32 values"
{
    a := strings.String(int32(65), int32(66), int32(67))
    @assert a == "ABC"
}


@test "packages: strings.String, mixed string and ints"
{
    a := strings.String(int32(65), "BC", int32(68))
    @assert a == "ABCD"
}


@test "packages: strings.String, invalid arg type"
{
    failed := false
    try {
        _ = strings.String(54, true)
    } catch(e) {
        failed = true
        @assert e.Code() == "arg.type"
    }

    @assert failed == true
}
