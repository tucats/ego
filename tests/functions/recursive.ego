@test "functions: recursive factorial"

// Test a function defined outside the scope of the text (i.e., with
// global scope). 
func factorial(n int) int {
    if n <= 1 {
        return 1
    }
    return n * factorial(n-1)
}

{
    @assert factorial(0)  == 1
    @assert factorial(1)  == 1
    @assert factorial(2)  == 2
    @assert factorial(3)  == 6
    @assert factorial(4)  == 24
    @assert factorial(5)  == 120
    @assert factorial(10) == 3628800
}

@test "functions: recursive fibonacci"

func fib(n int) int {
    if n <= 1 {
        return n
    }
    return fib(n-1) + fib(n-2)
}

{
    @assert fib(0)  == 0
    @assert fib(1)  == 1
    @assert fib(2)  == 1
    @assert fib(3)  == 2
    @assert fib(4)  == 3
    @assert fib(5)  == 5
    @assert fib(10) == 55
}

@test "functions: recursive sum of slice"

func sumSlice(a []int, i int) int {
    if i >= len(a) {
        return 0
    }
    return a[i] + sumSlice(a, i+1)
}

{
    @assert sumSlice([]int{1, 2, 3, 4, 5}, 0) == 15
    @assert sumSlice([]int{10}, 0)             == 10
    @assert sumSlice([]int{}, 0)               == 0
    @assert sumSlice([]int{-1, 1, -1, 1}, 0)  == 0
}

@test "functions: recursive power"

func power(base, exp int) int {
    if exp == 0 {
        return 1
    }
    return base * power(base, exp-1)
}

{
    @assert power(2, 0)  == 1
    @assert power(2, 1)  == 2
    @assert power(2, 8)  == 256
    @assert power(3, 4)  == 81
    @assert power(10, 3) == 1000
}

@test "functions: recursive function defined in block"

// Verifies that a recursive function defined inside a {} block (not at test
// scope) can still call itself.
{
    func countDown(n int) int {
        if n <= 0 {
            return 0
        }
        return 1 + countDown(n-1)
    }

    @assert countDown(0)  == 0
    @assert countDown(1)  == 1
    @assert countDown(5)  == 5
    @assert countDown(10) == 10
}
