// Tests for function scope, closures, and variable shadowing.

@test "functions: inner scope shadows outer variable"
{
    x := 10
    func f() int {
        x := 99
        return x
    }
    @assert f() == 99
    @assert x == 10
}

@test "functions: closure reads live outer variable"
{
    x := 5
    get := func() int { return x }
    @assert get() == 5
    x = 42
    @assert get() == 42
}

@test "functions: closure writes outer variable"
{
    count := 0
    inc := func() { count = count + 1 }
    inc()
    inc()
    inc()
    @assert count == 3
}

@test "functions: named func closure sees outer scope"
{
    total := 0
    func add(n int) {
        total = total + n
    }
    add(10)
    add(20)
    add(12)
    @assert total == 42
}

@test "functions: nested closures share captured variable"
{
    n := 0
    inc := func() { n = n + 1 }
    dec := func() { n = n - 1 }
    get := func() int { return n }

    inc()
    inc()
    inc()
    dec()

    @assert get() == 2
    @assert n == 2
}

@test "functions: closure in loop called immediately"
{
    // Calling closure immediately within a loop works correctly
    // because the loop variable is still in scope.
    var result []int
    for i := 0; i < 5; i = i + 1 {
        v := func() int { return i }()
        result = append(result, v)
    }

    @assert T.Equal(len(result), 5)
    @assert result[0] == 0
    @assert result[1] == 1
    @assert result[4] == 4
}

@test "functions: stored closure survives after loop"
{
    // BUG-30: updated for Go 1.22+ semantics. Each iteration of a "for" loop
    // now gets its own fresh copy of the loop variable "i", and a closure
    // created in the loop body captures THAT iteration's copy - not the
    // loop's single (persistent) counter variable. The last iteration to
    // run is i == 2 (the loop body executes for i == 0, 1, 2; the condition
    // "3 < 3" then fails and the loop exits without a fourth iteration), so
    // the closure stored on that iteration returns 2, not the post-loop
    // value of the counter (3). This matches real Go 1.22+ (verified with
    // "go run"); before Go 1.22 - and before this fix - every iteration's
    // closure shared one variable, so the result was 3 (whatever "i" ended
    // up holding after the loop, not what it held on any particular
    // iteration).
    captured := func() int { return 0 }
    for i := 0; i < 3; i = i + 1 {
        captured = func() int { return i }
    }

    r := captured()
    @assert r == 2
}

@test "functions: nested named funcs do not share scope"
{
    // DIFFERS FROM GO: Go does not allow nested named function declarations.
    // Ego allows them but named functions do not automatically see the
    // enclosing named function's parameters or locals - only closures do.
    func outer(a int) int {
        func inner(b int) int {
            return b * 2
        }
        return inner(a) + 1
    }

    @assert outer(5) == 11
    @assert outer(10) == 21
}

@test "functions: closure captures named func parameter"
{
    // A function literal (closure) defined inside a named function
    // CAN see the enclosing named function's parameters.
    func scale(factor int) int {
        multiply := func(x int) int {
            return x * factor
        }
        return multiply(7)
    }

    @assert scale(3) == 21
    @assert scale(6) == 42
}
