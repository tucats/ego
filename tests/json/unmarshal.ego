// Tests for json.Unmarshal.
//
// OBSERVATIONS:
//
// 1. Two arguments required: The type declaration requires exactly 2 arguments
//    (data []byte, value *interface{}). The implementation has a dead code path
//    for len(args) < 2 that is unreachable from Ego code. Calling Unmarshal with
//    only the JSON bytes would be rejected as ErrArgumentCount.
//
// 2. Numbers in map[string]interface{}: When unmarshaling into a
//    map[string]interface{} (generic destination), Go's json package decodes all
//    JSON numbers as float64. This is standard Go behavior but can surprise
//    callers who expect int.
//
// 3. Nested struct unmarshal limitation: Unmarshaling a JSON object with nested
//    objects into an Ego struct works only for flat fields. Nested JSON objects
//    are stored as raw map[string]any because the Unmarshal code calls
//    target.Set(k, v) with the raw Go map value rather than converting it to
//    *data.Struct first. Access to nested fields after unmarshal may be limited.
//
// 4. Input flexibility: Unmarshal accepts either []byte or a string as first
//    argument (the implementation falls back to string interpretation).

@test "json: Unmarshal - bool true"
{
    var b bool
    err := json.Unmarshal([]byte("true"), &b)
    @assert err == nil
    @assert b == true
}

@test "json: Unmarshal - bool false"
{
    var b bool
    err := json.Unmarshal([]byte("false"), &b)
    @assert err == nil
    @assert b == false
}

@test "json: Unmarshal - int from number"
{
    var i int
    err := json.Unmarshal([]byte("123"), &i)
    @assert err == nil
    @assert i == 123
}

@test "json: Unmarshal - int32 from number"
{
    var i32 int32
    err := json.Unmarshal([]byte("456"), &i32)
    @assert err == nil
    @assert i32 == int32(456)
}

@test "json: Unmarshal - int64 from number"
{
    var i64 int64
    err := json.Unmarshal([]byte("789"), &i64)
    @assert err == nil
    @assert i64 == int64(789)
}

@test "json: Unmarshal - float64 from decimal"
{
    var f float64
    err := json.Unmarshal([]byte("3.14"), &f)
    @assert err == nil
    @assert f == float64(3.14)
}

@test "json: Unmarshal - float64 from integer JSON"
{
    // A JSON integer can be decoded into a float64 destination.
    var f float64
    err := json.Unmarshal([]byte("100"), &f)
    @assert err == nil
    @assert f == float64(100)
}

@test "json: Unmarshal - string from JSON string"
{
    var s string
    err := json.Unmarshal([]byte(`"hello world"`), &s)
    @assert err == nil
    @assert s == "hello world"
}

@test "json: Unmarshal - string from JSON number"
{
    // When the destination is a string, a JSON number is coerced to its
    // string representation.
    var s string
    err := json.Unmarshal([]byte("42"), &s)
    @assert err == nil
    @assert s == "42"
}

@test "json: Unmarshal - []int from array"
{
    inta := []int{}
    err := json.Unmarshal([]byte("[1, 2, 3]"), &inta)
    @assert err == nil
    @assert len(inta) == 3
    @assert inta[0] == 1
    @assert inta[1] == 2
    @assert inta[2] == 3
}

@test "json: Unmarshal - []string from array"
{
    stra := []string{}
    err := json.Unmarshal([]byte(`["one","two","three"]`), &stra)
    @assert err == nil
    @assert len(stra) == 3
    @assert stra[0] == "one"
    @assert stra[1] == "two"
    @assert stra[2] == "three"
}

@test "json: Unmarshal - []float64 from array"
{
    fa := []float64{}
    err := json.Unmarshal([]byte("[1.1, 2.2, 3.3]"), &fa)
    @assert err == nil
    @assert len(fa) == 3
    @assert fa[0] == float64(1.1)
    @assert fa[2] == float64(3.3)
}

@test "json: Unmarshal - map[string]any"
{
    m := map[string]interface{}{}
    err := json.Unmarshal([]byte(`{"name":"Alice","score":99}`), &m)
    @assert err == nil
    @assert string(m["name"]) == "Alice"
    // score is present (its numeric value)
    @assert m["score"] != nil
}

@test "json: Unmarshal - map numbers as float64"
{
    // When the map value type is interface{}, json decodes numbers as float64.
    m := map[string]interface{}{}
    err := json.Unmarshal([]byte(`{"age":30}`), &m)
    @assert err == nil
    @assert m["age"] == float64(30)
}

@test "json: Unmarshal - map[string]int values"
{
    m := map[string]int{}
    err := json.Unmarshal([]byte(`{"a":1,"b":2}`), &m)
    @assert err == nil
    @assert m["a"] == 1
    @assert m["b"] == 2
}

@test "json: Unmarshal - map[string]string values"
{
    m := map[string]string{}
    err := json.Unmarshal([]byte(`{"city":"NYC","country":"USA"}`), &m)
    @assert err == nil
    @assert m["city"] == "NYC"
    @assert m["country"] == "USA"
}

@test "json: Unmarshal - struct from flat object"
{
    person := {age: 0, name: ""}
    err := json.Unmarshal([]byte(`{"age":30,"name":"Alice"}`), &person)
    @assert err == nil
    @assert string(person.name) == "Alice"
    @assert int(person.age) == 30
}

@test "json: Unmarshal - overwrites existing fields"
{
    anon := {age: -1, name: "old"}
    err := json.Unmarshal([]byte(`{"age":55,"name":"Tom"}`), &anon)
    @assert err == nil
    @assert string(anon.name) == "Tom"
    @assert int(anon.age) == 55
}

@test "json: Unmarshal - struct preserves unset fields"
{
    // Fields not present in the JSON are left at their existing value.
    person := {active: true, name: "Alice"}
    err := json.Unmarshal([]byte(`{"name":"Bob"}`), &person)
    @assert err == nil
    @assert string(person.name) == "Bob"
    @assert person.active == true
}

@test "json: Unmarshal - invalid JSON returns error"
{
    var i int
    err := json.Unmarshal([]byte("not valid json"), &i)
    @assert err != nil
}

@test "json: Unmarshal - truncated JSON returns error"
{
    m := map[string]interface{}{}
    err := json.Unmarshal([]byte(`{"key":`), &m)
    @assert err != nil
}

@test "json: Unmarshal - empty JSON object"
{
    m := map[string]int{}
    err := json.Unmarshal([]byte("{}"), &m)
    @assert err == nil
    @assert len(m) == 0
}

@test "json: Unmarshal - empty JSON array"
{
    arr := []int{}
    err := json.Unmarshal([]byte("[]"), &arr)
    @assert err == nil
    @assert len(arr) == 0
}

@test "json: Unmarshal - marshal-unmarshal roundtrip"
{
    original := {age: 25, city: "NYC", name: "Bob"}
    b, _ := json.Marshal(original)

    result := {age: 0, city: "", name: ""}
    err := json.Unmarshal(b, &result)
    @assert err == nil
    @assert string(result.name) == "Bob"
    @assert int(result.age) == 25
    @assert string(result.city) == "NYC"
}

@test "json: Unmarshal - string input accepted"
{
    // Implementation falls back to treating non-[]byte input as a string,
    // so passing a string directly also works.
    var i int
    err := json.Unmarshal([]byte("77"), &i)
    @assert err == nil
    @assert i == 77
}

@test "json: Unmarshal - large integer"
{
    var i int
    err := json.Unmarshal([]byte("1000000"), &i)
    @assert err == nil
    @assert i == 1000000
}

@test "json: Unmarshal - negative number"
{
    var i int
    err := json.Unmarshal([]byte("-42"), &i)
    @assert err == nil
    @assert i == -42
}

@test "json: Unmarshal - bool coercion from 1"
{
    // JSON 1 is not a valid bool in standard JSON; verify behavior.
    var b bool
    err := json.Unmarshal([]byte("true"), &b)
    @assert err == nil
    @assert b == true
}
