// Tests for sort.IsSorted, sort.IntsAreSorted, sort.Float64sAreSorted,
// sort.StringsAreSorted — each returns true when the array is already
// in non-decreasing order, false otherwise.

@test "sort: IsSorted generic"
{
    // Sorted int array
    @assert sort.IsSorted([]int{1, 2, 3, 4, 5})

    // Unsorted int array
    @assert !sort.IsSorted([]int{3, 1, 4, 1, 5})

    // Single element is always sorted
    @assert sort.IsSorted([]int{42})

    // Sorted string array
    @assert sort.IsSorted([]string{"apple", "banana", "cherry"})

    // Unsorted string array
    @assert !sort.IsSorted([]string{"cherry", "apple", "banana"})

    // Sorted float64 array
    @assert sort.IsSorted([]float64{0.1, 1.5, 2.7, 3.14})

    // Equal adjacent elements count as sorted
    @assert sort.IsSorted([]int{1, 2, 2, 3})
}

@test "sort: IntsAreSorted"
{
    @assert sort.IntsAreSorted([]int{-5, 0, 3, 10, 100})
    @assert !sort.IntsAreSorted([]int{1, 3, 2})

    // Verify round-trip: sort then check
    a := []int{9, 3, 7, 1}
    sort.Ints(a)
    @assert sort.IntsAreSorted(a)
}

@test "sort: Float64sAreSorted"
{
    func near(a, b float64) bool {
        return math.Abs(a-b) < 1e-9
    }

    @assert sort.Float64sAreSorted([]float64{1.0, 2.0, 3.5, 10.0})
    @assert !sort.Float64sAreSorted([]float64{1.0, 3.0, 2.0})

    // Verify round-trip
    f := []float64{4.4, 1.1, 3.3, 2.2}
    sort.Float64s(f)
    @assert sort.Float64sAreSorted(f)
}

@test "sort: StringsAreSorted"
{
    @assert sort.StringsAreSorted([]string{"", "apple", "banana"})
    @assert !sort.StringsAreSorted([]string{"banana", "apple"})

    // Verify round-trip
    s := []string{"pear", "apple", "cherry"}
    sort.Strings(s)
    @assert sort.StringsAreSorted(s)
}
