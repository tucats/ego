// Tests for sort.Sort — the generic sort that accepts an []interface{} array
// or a typed array and deduces the element type from the first element.
// sort.Sort modifies the array in-place and returns the same reference.

@test "sort: Sort integer array"
{
    a := []int{9, 3, 7, 1, 5}
    a2 := sort.Sort(a)

    // In-place: return value is the same array
    @assert a[0] == a2[0]

    // Sorted ascending
    @assert a[0] == 1
    @assert a[1] == 3
    @assert a[2] == 5
    @assert a[3] == 7
    @assert a[4] == 9
}

@test "sort: Sort string array"
{
    a := []string{"pear", "apple", "fig", "cherry"}
    sort.Sort(a)

    @assert a[0] == "apple"
    @assert a[1] == "cherry"
    @assert a[2] == "fig"
    @assert a[3] == "pear"
}

@test "sort: Sort float64 array"
{
    func near(a, b float64) bool {
        return math.Abs(a-b) < 1e-9
    }

    a := []float64{3.3, 1.1, 4.4, 2.2}
    sort.Sort(a)

    @assert near(a[0], 1.1)
    @assert near(a[1], 2.2)
    @assert near(a[2], 3.3)
    @assert near(a[3], 4.4)
}

@test "sort: Sort int64 array"
{
    a := []int64{500, 100, 400, 200, 300}
    sort.Sort(a)

    @assert int(a[0]) == 100
    @assert int(a[1]) == 200
    @assert int(a[2]) == 300
    @assert int(a[3]) == 400
    @assert int(a[4]) == 500
}

@test "sort: Sort int32 array"
{
    a := []int32{8, 2, 6, 4, 10}
    sort.Sort(a)

    @assert int(a[0]) == 2
    @assert int(a[1]) == 4
    @assert int(a[2]) == 6
    @assert int(a[3]) == 8
    @assert int(a[4]) == 10
}

@test "sort: Sort single-element and already-sorted"
{
    single := []int{42}
    sort.Sort(single)
    @assert single[0] == 42

    sorted := []int{1, 2, 3, 4, 5}
    sort.Sort(sorted)
    @assert sorted[0] == 1
    @assert sorted[4] == 5
}

@test "sort: Sort negative integers"
{
    a := []int{0, -5, 10, -2, 3}
    sort.Sort(a)

    @assert a[0] == -5
    @assert a[1] == -2
    @assert a[2] == 0
    @assert a[3] == 3
    @assert a[4] == 10
}

@test "sort: Sort float32 preserves float32 type"
{
    // Bug fix: genericSort previously created a Float64Type result array for
    // float32 inputs.  Verify the sorted result still holds float32 values.
    a := []float32{5.0, 2.0, 8.0, 1.0, 3.0}
    sort.Sort(a)

    @assert a[0] == float32(1.0)
    @assert a[1] == float32(2.0)
    @assert a[2] == float32(3.0)
    @assert a[3] == float32(5.0)
    @assert a[4] == float32(8.0)
}

@test "sort: Sort returns (value, error) like other packages"
{
    // Regression test: every function in the sort package used to be
    // declared with only its primary return value, no error -- so a plain
    // "v, err := sort.Sort(x)" could never compile, and any failure became
    // an uncatchable-except-try/catch runtime error. All sort functions now
    // return (value, error) per the runtime's standard convention.
    a := []int{9, 3, 7, 1, 5}
    v, err := sort.Sort(a)
    @assert err == nil
    @assert v[0] == 1
    @assert v[4] == 9
}

@test "sort: Sort on an unsupported element type returns an error"
{
    // bool arrays are not one of sort's supported element kinds.
    v, err := sort.Sort([]bool{true, false})
    @assert err != nil
    @assert v != nil   // in-place: the (unsorted) array is still returned
}

@test "sort: Sort on a complex128 array returns an error, not a panic"
{
    // complex128 has no natural ordering (no "<" in Go either), so it is
    // deliberately not one of sort's supported element kinds -- this locks
    // in that the rejection is a clean error, not a panic.
    v, err := sort.Sort([]complex128{3 + 4i, 1 + 1i})
    @assert err != nil
    @assert v != nil
}
