// Tests for reflect.DeepCopy() — recursively copies an Ego value.
// Scalars are returned as-is (they are already value types).
// Structs, maps, and arrays are copied so the result is independent.

@test "reflect: DeepCopy() scalars return as-is"
{
    @assert reflect.DeepCopy(42) == 42
    @assert typeof(reflect.DeepCopy(42)) == int

    @assert reflect.DeepCopy("hello") == "hello"
    @assert typeof(reflect.DeepCopy("hello")) == string

    @assert reflect.DeepCopy(true) == true
    @assert reflect.DeepCopy(3.14) == 3.14
    @assert reflect.DeepCopy(int32(7)) == int32(7)
    @assert reflect.DeepCopy(int64(100)) == int64(100)
    @assert reflect.DeepCopy(byte(255)) == byte(255)
}

@test "reflect: DeepCopy() of nil returns nil"
{
    c := reflect.DeepCopy(nil)
    @assert c == nil
}

@test "reflect: DeepCopy() struct is independent"
{
    type Point struct { x int; y int }
    p := Point{ x: 10, y: 20 }
    c := reflect.DeepCopy(p)

    // Values match
    @assert c.x == 10
    @assert c.y == 20

    // Modifying the copy does not affect the original
    c.x = 99
    @assert p.x == 10
}

@test "reflect: DeepCopy() of nested struct"
{
    type Inner struct { value int }
    type Outer struct { inner Inner; label string }
    o := Outer{ inner: Inner{ value: 42 }, label: "test" }
    c := reflect.DeepCopy(o)

    @assert c.label == "test"
    @assert c.inner.value == 42
}

@test "reflect: DeepCopy() struct field with array is independent"
{
    // Regression test: Struct.Copy() (used internally by DeepCopy for the
    // top-level struct) only duplicates the field map itself -- the values
    // in that map, such as a nested array, were still shared with the
    // original. Mutating the copy's array field used to mutate the
    // original's too.
    type Holder struct { tags []string }
    h := Holder{ tags: []string{"a", "b"} }
    c := reflect.DeepCopy(h)

    c.tags[0] = "Z"

    @assert h.tags[0] == "a"
    @assert c.tags[0] == "Z"
}

@test "reflect: DeepCopy() struct field with map is independent"
{
    type Holder struct { counts map[string]int }
    h := Holder{ counts: map[string]int{"a": 1} }
    c := reflect.DeepCopy(h)

    c.counts["a"] = 99

    @assert h.counts["a"] == 1
    @assert c.counts["a"] == 99
}

@test "reflect: DeepCopy() bad depth argument is a catchable error"
{
    // Regression test: DeepCopy() used to be declared with only a single
    // (value) return even though a non-numeric depth argument produces a
    // real error, so the failure could only be observed via an uncaught,
    // program-aborting runtime error. It now returns (value, error).
    //
    // A string literal for the int-typed "depth" parameter is rejected at
    // compile time in strict mode (a stronger, earlier form of the same
    // protection) and only reaches the runtime check in dynamic mode, so
    // @compile is used here to accept either outcome as correct: an empty
    // catch swallows the strict-mode compile error, while in dynamic mode
    // the spliced-in code runs and its own @assert checks the runtime error.
    @compile block {
        _, err := reflect.DeepCopy(42, "not-a-number")
        @assert err != nil
    } catch {}
}

@test "reflect: DeepCopy() map is independent"
{
    m := map[string]int{ "a": 1, "b": 2, "c": 3 }
    c := reflect.DeepCopy(m)

    @assert typeof(c) == map[string]int
    @assert len(c) == 3
    @assert c["a"] == 1
    @assert c["b"] == 2
    @assert c["c"] == 3
}

@test "reflect: DeepCopy() array is independent"
{
    a := []int{10, 20, 30}
    c := reflect.DeepCopy(a)

    @assert typeof(c) == []int
    @assert len(c) == 3
    @assert c[0] == 10
    @assert c[1] == 20
    @assert c[2] == 30
    // Original is unchanged
    @assert a[0] == 10
}

@test "reflect: DeepCopy() optional depth parameter"
{
    // depth=1 means copy the top level only; depth=0 is an edge case
    p := 42
    c1 := reflect.DeepCopy(p, 1)
    @assert c1 == 42

    c0 := reflect.DeepCopy(p, 0)
    @assert c0 == 42
}
