// Tests for reflect.Members() — returns a sorted []string of field/key names.
// Works on structs, maps, and packages; returns an error for other types.
//
// Regression note: Members() used to be declared with a single ([]string)
// return even though it can genuinely fail (a scalar or array argument), so
// the error could only be observed via try/catch -- an uncaught call would
// abort the whole program. It now returns ([]string, error) like every other
// fallible function in this package, so the error is caught normally, no
// try/catch required.

@test "reflect: Members() on struct, field names"
{
    type Employee struct { name string; department string; salary int }
    e := Employee{ name: "Alice", department: "Eng", salary: 100 }
    m := reflect.Members(e)

    @assert typeof(m) == []string
    @assert len(m) == 3
    // Members preserves field declaration order for structs
    @assert m[0] == "name"
    @assert m[1] == "department"
    @assert m[2] == "salary"
}

@test "reflect: Members() on an anonymous struct"
{
    s := struct{ x int; y int }{ x: 10, y: 20 }
    m := reflect.Members(s)

    @assert len(m) == 2
    @assert m[0] == "x"
    @assert m[1] == "y"
}

@test "reflect: Members() on a map returns sorted keys"
{
    mp := map[string]int{ "zebra": 1, "apple": 2, "mango": 3 }
    m := reflect.Members(mp)

    @assert typeof(m) == []string
    @assert len(m) == 3
    // Map keys are sorted alphabetically
    @assert m[0] == "apple"
    @assert m[1] == "mango"
    @assert m[2] == "zebra"
}

@test "reflect: Members() on an empty map"
{
    mp := map[string]int{}
    m := reflect.Members(mp)

    @assert len(m) == 0
}

@test "reflect: Members() on a package"
{
    m := reflect.Members(strings)

    @assert typeof(m) == []string
    @assert len(m) > 0
    // Verify some known members are present
    @assert index(m, "Builder") >= 0
    @assert index(m, "Camel") >= 0
    @assert index(m, "Contains") >= 0
    @assert index(m, "Join") >= 0
    @assert index(m, "Split") >= 0
}

@test "reflect: Members() errors on scalars"
{
    _, err := reflect.Members(42)
    @assert err != nil

    _, err2 := reflect.Members("hello")
    @assert err2 != nil
}

@test "reflect: Members() errors on arrays"
{
    _, err := reflect.Members([]int{1, 2, 3})
    @assert err != nil
}
