// Tests for reflect.InstanceOf() — creates a zero-value instance based on
// its argument.
//
// Behavior depends on the argument:
//   - *data.Type (a type value, e.g. the built-in "int" or a user-defined
//     type name, or the result of reflect.Type()) → zero value of that type
//   - a channel → returned unchanged (channels have no zero-value concept)
//   - any other value (scalar, struct, array, map) → zero value of THAT
//     value's own type, not a copy of the value itself
//
// Regression note: this used to also accept a string type name ("int",
// "bool", etc.) and a raw Go reflect.Kind integer constant. Both were
// removed:
//   - The string form is redundant now that types are first-class Ego
//     values -- pass the built-in type itself (reflect.InstanceOf(int)),
//     not its name as a string.
//   - The Kind-integer form was never intentional. Because Ego ints and Go's
//     reflect.Kind constants are indistinguishable at the Go level (both are
//     plain "int"), passing an ordinary Ego int VALUE collided with it: e.g.
//     reflect.InstanceOf(3) used to misinterpret the value 3 as
//     reflect.Kind(3) (Int8) and return byte(0) instead of an int zero
//     value, and reflect.InstanceOf(0) (Kind 0 is reflect.Invalid) errored
//     outright. Passing any plain scalar example value now correctly
//     returns the zero value of THAT value's own type -- see below.

@test "reflect: InstanceOf() from a built-in type value"
{
    @assert reflect.InstanceOf(int) == 0
    @assert typeof(reflect.InstanceOf(int)) == int

    @assert reflect.InstanceOf(int32) == int32(0)
    @assert typeof(reflect.InstanceOf(int32)) == int32

    @assert reflect.InstanceOf(int64) == int64(0)
    @assert typeof(reflect.InstanceOf(int64)) == int64

    @assert reflect.InstanceOf(byte) == byte(0)
    @assert typeof(reflect.InstanceOf(byte)) == byte

    @assert reflect.InstanceOf(float32) == float32(0)
    @assert typeof(reflect.InstanceOf(float32)) == float32

    @assert reflect.InstanceOf(float64) == 0.0
    @assert typeof(reflect.InstanceOf(float64)) == float64

    @assert reflect.InstanceOf(string) == ""
    @assert typeof(reflect.InstanceOf(string)) == string

    @assert reflect.InstanceOf(bool) == false
    @assert typeof(reflect.InstanceOf(bool)) == bool
}

@test "reflect: InstanceOf() from a type variable"
{
    // A variable of type "type" (see the "Type as a value" section of the
    // reflect docs) works exactly like a bare built-in type name.
    t := int
    @assert reflect.InstanceOf(t) == 0
    @assert typeof(reflect.InstanceOf(t)) == int

    t = string
    @assert reflect.InstanceOf(t) == ""
}

@test "reflect: InstanceOf() from a plain scalar example value"
{
    // Regression coverage: passing an ordinary scalar VALUE (not a type,
    // not a Kind number) must return the zero value of that value's own
    // type -- this used to collide with the removed Kind-integer form.
    @assert reflect.InstanceOf(0) == 0
    @assert reflect.InstanceOf(42) == 0
    @assert typeof(reflect.InstanceOf(42)) == int

    @assert reflect.InstanceOf(int32(7)) == int32(0)
    @assert typeof(reflect.InstanceOf(int32(7))) == int32

    @assert reflect.InstanceOf(int64(7)) == int64(0)
    @assert typeof(reflect.InstanceOf(int64(7))) == int64

    @assert reflect.InstanceOf(byte(7)) == byte(0)
    @assert typeof(reflect.InstanceOf(byte(7))) == byte

    @assert reflect.InstanceOf(float32(1.5)) == float32(0)
    @assert typeof(reflect.InstanceOf(float32(1.5))) == float32

    @assert reflect.InstanceOf(1.5) == 0.0
    @assert typeof(reflect.InstanceOf(1.5)) == float64

    @assert reflect.InstanceOf("hello") == ""
    @assert typeof(reflect.InstanceOf("hello")) == string

    @assert reflect.InstanceOf(true) == false
    @assert typeof(reflect.InstanceOf(true)) == bool
}

@test "reflect: InstanceOf() from type definition"
{
    type Dimensions struct { width int; height int; depth int }

    // Passing the type definition creates a zero-value instance
    z := reflect.InstanceOf(Dimensions)
    @assert typeof(z) == Dimensions
    @assert z.width == 0
    @assert z.height == 0
    @assert z.depth == 0
}

@test "reflect: InstanceOf() on struct value gives zero"
{
    type Config struct { host string; port int }
    c := Config{ host: "localhost", port: 9090 }

    // Passing an instance returns a zero-value of the same type
    c2 := reflect.InstanceOf(c)
    @assert typeof(c2) == Config
    @assert c2.host == ""
    @assert c2.port == 0

    // Original is unchanged
    @assert c.host == "localhost"
    @assert c.port == 9090
}

@test "reflect: InstanceOf() on array value gives empty"
{
    a := []int{10, 20, 30}
    c := reflect.InstanceOf(a)
    @assert typeof(c) == []int
    // Zero-value array is empty, not a copy of the data
    @assert len(c) == 0
}

@test "reflect: InstanceOf() on map value gives empty"
{
    m := map[string]int{ "a": 1, "b": 2 }
    c := reflect.InstanceOf(m)
    @assert typeof(c) == map[string]int
    // Zero-value map is empty, not a copy of the data
    @assert len(c) == 0
}
