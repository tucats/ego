// Tests for explicit type conversions (casts) in Ego.
//
// DIFFERENCES FROM GO:
// 1. string(intValue) produces the decimal representation, e.g. string(65) == "65".
//    In Go, string(65) produces "A" (the Unicode code point). Ego treats it as
//    a number-to-string conversion, not a rune-to-string conversion.
// 2. []int(str) converts a string to a []int of Unicode code points (rune values).
//    string([]int{...}) converts back. This is the Ego mechanism for what Go
//    calls []rune / string conversion.

@test "types: int to float64"
{
    i := 42
    f := float64(i)
    @assert f == float64(42)
    @assert reflect.Type(f) == float64
}

@test "types: float64 to int truncates toward zero"
{
    // Positive: truncates down
    @assert int(3.9) == 3
    @assert int(3.1) == 3
    // Negative: truncates toward zero (not floor)
    @assert int((-3.9)) == -3
    @assert int((-3.1)) == -3
}

@test "types: float64 to float32"
{
    f64 := float64(1.5)
    f32 := float32(f64)
    @assert reflect.Type(f32) == float32
    @assert f32 == float32(1.5)
}

@test "types: float32 to float64"
{
    f32 := float32(2.5)
    f64 := float64(f32)
    @assert reflect.Type(f64) == float64
}

@test "types: int to int8 narrowing"
{
    i := int8(100)
    @assert reflect.Type(i) == int8
    @assert int(i) == 100
}

@test "types: int to int32 narrowing"
{
    i := int32(1000000)
    @assert reflect.Type(i) == int32
    @assert int(i) == 1000000
}

@test "types: int to int64"
{
    i := int64(999999999999)
    @assert reflect.Type(i) == int64
    @assert i == int64(999999999999)
}

@test "types: string(int) is decimal, not rune"
{
    // Ego: string(65) == "65", not "A"
    // In Go string(65) would produce "A" (Unicode code point 65).
    s := string(65)
    @assert s == "65"
}

@test "types: int(string) parses decimal"
{
    @assert int("42") == 42
    @assert int("0") == 0
    @assert int("-7") == -7
}

@test "types: int(empty string) is zero"
{
    @assert int("") == 0
}

@test "types: float64(string) parses decimal"
{
    @assert float64("3.14") == float64(3.14)
    @assert float64("0") == float64(0)
}

@test "types: string(float64)"
{
    s := string(3.14)
    @assert len(s) > 0
    @assert s == "3.14"
}

@test "types: bool(int) zero is false"
{
    @assert bool(0) == false
    @assert bool(1) == true
    @assert bool(2) == true
    @assert bool(-1) == true
}

@test "types: bool(string) values"
{
    @assert bool("true") == true
    @assert bool("false") == false
    @assert bool("1") == true
    @assert bool("0") == false
    @assert bool("t") == true
    @assert bool("f") == false
    @assert bool("") == false
}

@test "types: string(bool)"
{
    @assert string(true) == "true"
    @assert string(false) == "false"
}

@test "types: []byte from string"
{
    b := []byte("ABC")
    @assert len(b) == 3
    @assert int(b[0]) == 65
    @assert int(b[1]) == 66
    @assert int(b[2]) == 67
    @assert reflect.Type(b) == []byte
}

@test "types: string from []byte"
{
    b := []byte{72, 101, 108, 108, 111}
    s := string(b)
    @assert s == "Hello"
}

@test "types: []byte/string roundtrip"
{
    original := "hello world"
    b := []byte(original)
    restored := string(b)
    @assert restored == original
}

@test "types: []int from string gives code points"
{
    // []int("ABC") gives Unicode code points [65, 66, 67]
    r := []int("ABC")
    @assert len(r) == 3
    @assert r[0] == 65
    @assert r[1] == 66
    @assert r[2] == 67
}

@test "types: string from []int roundtrip"
{
    r := []int{72, 101, 108, 108, 111}
    s := string(r)
    @assert s == "Hello"
}

@test "types: string(nil) is empty"
{
    @assert string(nil) == ""
}

@test "types: bool(nil) is false"
{
    @assert bool(nil) == false
}

@test "types: int(nil) is zero"
{
    @assert int(nil) == 0
}

@test "types: float64(nil) is zero"
{
    @assert float64(nil) == float64(0)
}

@test "types: byte from int"
{
    b := byte(65)
    @assert int(b) == 65
    @assert reflect.Type(b) == byte
}

// NOTE: uint8 is not a recognized type keyword; use byte instead.
// byte(200) and int(byte(200)) work correctly.
@test "types: byte cast at maximum value"
{
    b := byte(200)
    @assert int(b) == 200
    @assert reflect.Type(b) == byte
}
