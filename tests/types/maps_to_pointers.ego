@test "types: maps of pointer types"
{

    // Initialize the map before writing to it: "var a map[string]*int" alone
    // produces a nil map (matching Go semantics); writes require an initializer.
    a := map[string]*int{}

    age := 55
    a["name"] = &age

    b := a["name"]
    @assert *b == 55
    @assert reflect.Type(a) == map[string]*int
}
