// Tests for array creation, operations, and iteration in Ego.
//
// DIFFERENCES FROM GO:
// 1. Anonymous arrays use [] syntax: [1, 2, 3] produces a []interface{} array.
//    In Go there are no anonymous slice/array literals like this.
// 2. Typed array literals use Go's []T{} syntax.
// 3. append() returns a new extended array (Ego arrays are otherwise fixed-size).

@test "types: anonymous array literal"
{
    a := [1, 2, 3]
    @assert len(a) == 3
    @assert a[0] == 1
    @assert a[1] == 2
    @assert a[2] == 3
}

@test "types: anonymous array is []interface{}"
{
    a := [1, "two", true]
    @assert len(a) == 3
    @assert a[0] == 1
    @assert a[1] == "two"
    @assert a[2] == true
    @assert reflect.Type(a) == []interface{}
}

@test "types: typed int array literal"
{
    a := []int{10, 20, 30}
    @assert len(a) == 3
    @assert a[0] == 10
    @assert a[1] == 20
    @assert a[2] == 30
    @assert reflect.Type(a) == []int
}

@test "types: typed string array literal"
{
    a := []string{"alpha", "beta", "gamma"}
    @assert len(a) == 3
    @assert a[0] == "alpha"
    @assert a[2] == "gamma"
    @assert reflect.Type(a) == []string
}

@test "types: typed bool array literal"
{
    a := []bool{true, false, true, false}
    @assert len(a) == 4
    @assert a[0] == true
    @assert a[1] == false
    @assert reflect.Type(a) == []bool
}

@test "types: typed float64 array"
{
    a := []float64{1.1, 2.2, 3.3}
    @assert len(a) == 3
    @assert a[0] == float64(1.1)
    @assert reflect.Type(a) == []float64
}

@test "types: empty typed array"
{
    a := []int{}
    @assert len(a) == 0
    @assert reflect.Type(a) == []int
}

@test "types: append extends array"
{
    a := []int{1, 2, 3}
    b := append(a, 4)
    @assert len(b) == 4
    @assert b[3] == 4
    // original is unchanged
    @assert len(a) == 3
}

@test "types: append multiple elements"
{
    a := []string{"a", "b"}
    b := append(a, "c", "d", "e")
    @assert len(b) == 5
    @assert b[4] == "e"
}

@test "types: array slicing a[lo:hi]"
{
    a := []int{10, 20, 30, 40, 50}
    s := a[1:4]
    @assert len(s) == 3
    @assert s[0] == 20
    @assert s[1] == 30
    @assert s[2] == 40
}

@test "types: array slice from start"
{
    a := []int{10, 20, 30, 40, 50}
    s := a[0:3]
    @assert len(s) == 3
    @assert s[0] == 10
    @assert s[2] == 30
}

@test "types: array slice to end"
{
    a := []int{10, 20, 30, 40, 50}
    s := a[2:5]
    @assert len(s) == 3
    @assert s[0] == 30
    @assert s[2] == 50
}

@test "types: array index assignment"
{
    a := []int{1, 2, 3}
    a[1] = 99
    @assert a[1] == 99
    @assert a[0] == 1
    @assert a[2] == 3
}

@test "types: range over array gives index and value"
{
    a := []int{10, 20, 30}
    sum := 0
    count := 0
    for i, v := range a {
        sum = sum + v
        count = count + i
    }
    @assert sum == 60
    @assert count == 3  // 0+1+2
}

@test "types: range with blank index"
{
    a := []string{"x", "y", "z"}
    result := ""
    for _, v := range a {
        result = result + v
    }
    @assert result == "xyz"
}

@test "types: range with index only"
{
    a := []int{5, 6, 7}
    last := 0
    for i := range a {
        last = i
    }
    @assert last == 2
}

@test "types: nested array access"
{
    a := [][]int{
        {1, 2, 3},
        {4, 5, 6},
    }
    @assert a[0][0] == 1
    @assert a[0][2] == 3
    @assert a[1][0] == 4
    @assert a[1][2] == 6
}

@test "types: array of strings range"
{
    words := []string{"one", "two", "three"}
    total := 0
    for _, w := range words {
        total = total + len(w)
    }
    // "one"=3 "two"=3 "three"=5 = 11
    @assert total == 11
}

@test "types: len of nil is zero"
{
    var a []int
    @assert len(a) == 0
}

@test "types: typed []interface{} array"
{
    a := []interface{}{1, "hello", true, 3.14}
    @assert len(a) == 4
    @assert a[0] == 1
    @assert a[1] == "hello"
    @assert reflect.Type(a) == []interface{}
}

@test "types: array contains updated values"
{
    // NOTE: for-range iterates over a copy; use index loop to mutate in place.
    a := []int{0, 0, 0}
    for i := 0; i < len(a); i++ {
        a[i] = (i + 1) * 10
    }
    @assert a[0] == 10
    @assert a[1] == 20
    @assert a[2] == 30
}
