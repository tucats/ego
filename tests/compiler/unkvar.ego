@test "compiler: unknown variable"
{
    failed := false

    // The compiler will report two errors, that "bob" is not found, and
    // that "unused" is unused.
    @compile block unknown=true unused=true {

        unused := bob

    } catch(e) {
        failed = true
        @assert e.Code() == "symbol.not.found"
        @assert e.Unwrap() == "bob"

        second := e.Next()
        @assert second.Code() == "var.unused"
        @assert second.Unwrap() == "unused"
    }

    @assert failed == true
}
