// Tests for strconv.Quote and strconv.Unquote: Go-syntax string quoting.

@test "strconv: Quote wraps string in double-quotes"
{
    @assert strconv.Quote("hello")     == `"hello"`
    @assert strconv.Quote("")          == `""`
    @assert strconv.Quote("world")     == `"world"`
    @assert strconv.Quote("abc 123")   == `"abc 123"`

    // Return type is string
    @assert typeof(strconv.Quote("x")) == string
}

@test "strconv: Quote escapes special characters"
{
    // Double-quote inside the string becomes \"
    @assert strconv.Quote(`say "hi"`) == `"say \"hi\""`

    // Backslash becomes \\
    @assert strconv.Quote(`a\b`) == `"a\\b"`

    // Newline becomes \n
    @assert strconv.Quote("line1\nline2") == `"line1\nline2"`

    // Tab becomes \t
    @assert strconv.Quote("a\tb") == `"a\tb"`

    // Null byte becomes \x00
    @assert strconv.Quote("\x00") == `"\x00"`
}

@test "strconv: Unquote removes surrounding quotes"
{
    s, err := strconv.Unquote(`"hello"`)
    @assert err == nil
    @assert s == "hello"

    s, err = strconv.Unquote(`""`)
    @assert err == nil
    @assert s == ""

    s, err = strconv.Unquote(`"abc 123"`)
    @assert err == nil
    @assert s == "abc 123"

    // Return type is string
    @assert typeof(s) == string
}

@test "strconv: Unquote decodes escape sequences"
{
    s, err := strconv.Unquote(`"line1\nline2"`)
    @assert err == nil
    @assert s == "line1\nline2"

    s, err = strconv.Unquote(`"a\tb"`)
    @assert err == nil
    @assert s == "a\tb"

    s, err = strconv.Unquote(`"say \"hi\""`)
    @assert err == nil
    @assert s == `say "hi"`

    s, err = strconv.Unquote(`"a\\b"`)
    @assert err == nil
    @assert s == `a\b`
}

@test "strconv: Unquote, single-quoted rune literals"
{
    // Build the input string "'a'" by concatenation.
    // NOTE: in Ego source, "'a'" is the character literal int32(97), not
    // the 3-character string 'a'. Use a concat to build it explicitly.
    q := "'"
    s, err := strconv.Unquote(q + "a" + q)
    @assert err == nil
    @assert s == "a"

    s, err = strconv.Unquote(q + "z" + q)
    @assert err == nil
    @assert s == "z"

    s, err = strconv.Unquote(q + "+" + q)
    @assert err == nil
    @assert s == "+"
}

@test "strconv: Unquote returns error for invalid input"
{
    // Not quoted at all
    _, err := strconv.Unquote("hello")
    @assert err != nil

    // Only opening quote
    _, err = strconv.Unquote(`"hello`)
    @assert err != nil

    // Only closing quote
    _, err = strconv.Unquote(`hello"`)
    @assert err != nil

    // Empty string
    _, err = strconv.Unquote("")
    @assert err != nil

    // Mismatched quotes
    _, err = strconv.Unquote(`"hello'`)
    @assert err != nil
}

@test "strconv: Quote and Unquote round-trip"
{
    for _, v := range []string{"hello", "", "a b c", "line1\nline2", `say "hi"`} {
        q := strconv.Quote(v)
        s, err := strconv.Unquote(q)
        @assert err == nil
        @assert s == v
    }
}
