// Tests for Go-style parallel (multi-value) assignment support:
//
//   a, b, c = 10, 20, 30
//   a, b, c := 10, 20, 30
//   var a, b, c int = 10, 20, 30
//   var a, b, c = 10, "hello", true
//
// See internal/language/compiler/assignment.go (compileParallelAssignment)
// and internal/language/compiler/var.go (varInitializerList and the
// varInferredInitializer list branch) for the implementation.
//
// A target list containing an indexed or member lvalue (e.g. "m[k], arr[i]
// = ...") is covered separately, below, in the BUG-24 section -- that used
// to be a known limitation (rejected at runtime with "invalid or
// unsupported data type for this operation") but is now fixed. All targets
// in the tests above this point are simple names.

@test "datamodel: parallel assignment with = and pre-declared variables"
{
    var a, b, c int
    a, b, c = 10, 20, 30

    @assert a == 10
    @assert b == 20
    @assert c == 30
}

@test "datamodel: parallel assignment with :="
{
    x, y, z := 1, 2, 3

    @assert x == 1
    @assert y == 2
    @assert z == 3
}

@test "datamodel: parallel assignment two-value swap"
{
    a := 1
    b := 2

    a, b = b, a

    @assert a == 2
    @assert b == 1
}

@test "datamodel: parallel assignment three-value rotation"
{
    a := 1
    b := 2
    c := 3

    a, b, c = c, a, b

    @assert a == 3
    @assert b == 1
    @assert c == 2
}

@test "datamodel: parallel assignment RHS can be arbitrary expressions"
{
    x := 10
    y := 20

    a, b := x + 1, y * 2

    @assert a == 11
    @assert b == 40
}

@test "datamodel: parallel assignment with blank identifier target"
{
    a, _, c := 1, 2, 3

    @assert a == 1
    @assert c == 3
}

@test "datamodel: parallel assignment re-uses already-declared variables with ="
{
    var a int
    var b int

    a, b = 5, 6
    @assert a == 5
    @assert b == 6

    // Re-assign again to confirm this isn't a one-shot SymbolCreate.
    a, b = 7, 8
    @assert a == 7
    @assert b == 8
}

@test "datamodel: multi-return call assignment still works"
{
    // Regression guard: the single-expression path (a call that itself
    // produces multiple values) must be unaffected by the new
    // comma-separated-RHS-list path.
    func pair() (int, int) {
        return 55, 66
    }

    a, b := pair()
    @assert a == 55
    @assert b == 66
}

@test "datamodel: two-value channel receive still works"
{
    // Regression guard: v, ok := <-ch uses the same multi-target lvalue
    // machinery and must still work after adding RHS expression lists.
    ch := make(chan, 1)
    ch <- 42
    close(ch)

    v, ok := <-ch
    @assert v == 42
    @assert ok == true
}

@test "datamodel: parallel assignment errors on too many RHS values"
{
    var failed bool

    @compile block {
        var a, b int
        a, b = 1, 2, 3
    } catch(e) {
        failed = true
        @assert e.Code() == "assignment.count"
    }

    @assert failed == true
}

@test "datamodel: parallel assignment errors on too few RHS values"
{
    var failed bool

    @compile block {
        var a, b, c int
        a, b, c = 1, 2
    } catch(e) {
        failed = true
        @assert e.Code() == "assignment.count"
    }

    @assert failed == true
}

@test "datamodel: var with typed per-name initializer list"
{
    var a, b, c int = 10, 20, 30

    @assert a == 10
    @assert b == 20
    @assert c == 30
}

@test "datamodel: var with inferred per-name initializer list of mixed types"
{
    // Each name gets its own value and its own inferred type -- unlike the
    // single-shared-value form (var a, b = 42), the values here need not
    // even be the same type.
    var a, b, c = 10, "hello", true

    @assert a == 10
    @assert b == "hello"
    @assert c == true
}

@test "datamodel: var(...) list mixing typed and inferred per-name lists"
{
    var (
        a, b int = 1, 2
        c, d     = "x", "y"
    )

    @assert a == 1
    @assert b == 2
    @assert c == "x"
    @assert d == "y"
}

@test "datamodel: var shared-value broadcast is unaffected by the list fix"
{
    // A single initializer expression (no comma) still duplicates its value
    // across every declared name -- this is pre-existing, intentional
    // behavior (see BUG-17 test coverage) and must not regress.
    var a, b int = 42
    @assert a == 42
    @assert b == 42

    var x, y = 7
    @assert x == 7
    @assert y == 7
}

@test "datamodel: var errors on too many typed initializer values"
{
    var failed bool

    @compile block {
        var a, b int = 1, 2, 3
        _ = a
        _ = b
    } catch(e) {
        failed = true
        @assert e.Code() == "assignment.count"
    }

    @assert failed == true
}

@test "datamodel: var errors on too few typed initializer values"
{
    var failed bool

    @compile block {
        var a, b, c int = 1, 2
        _ = a
        _ = b
        _ = c
    } catch(e) {
        failed = true
        @assert e.Code() == "assignment.count"
    }

    @assert failed == true
}

@test "datamodel: var errors on too few inferred initializer values"
{
    var failed bool

    @compile block {
        var a, b, c = 1, 2
        _ = a
        _ = b
        _ = c
    } catch(e) {
        failed = true
        @assert e.Code() == "assignment.count"
    }

    @assert failed == true
}

// The tests below are regression tests for BUG-24: a multi-target
// assignment list containing an indexed or member lvalue ("m[\"k\"], arr[0]
// = ...") failed at runtime, either with a generic "invalid or unsupported
// data type for this operation" error, or (once the first symptom was
// fixed) silently storing the WRONG value into a later compound target.
//
// Two independent, compounding root causes were involved, both in
// internal/language/compiler/lvalue.go's assignmentTargetList and the
// bytecode it builds:
//
//  1. The loop unconditionally emitted a SymbolOptCreate instruction for
//     EVERY target in the list, compound or not, immediately before
//     calling patchStore. patchStore decides whether to convert a compound
//     lvalue's trailing LoadIndex into StoreIndex by checking whether the
//     LAST instruction emitted so far is exactly that LoadIndex -- the
//     unconditional SymbolOptCreate landing in between made that check
//     fail every time, so patchStore fell back to an ordinary Store on the
//     base variable's own name (e.g. "m") instead of storing into the
//     map/array/struct element at all. Fixed by only emitting
//     SymbolOptCreate for a genuinely simple (non-compound) target.
//
//  2. Once (1) was fixed and StoreIndex started being emitted correctly,
//     a second bug surfaced: storeIndexByteCode (internal/language/
//     bytecode/structs.go) pushes its container back onto the stack after
//     a successful write (storeInMap, storeInArray, and the struct
//     branches all do this). For a single-target assignment that leftover
//     value is harmless -- the enclosing "let" stack marker's
//     DropToMarker cleans up any stray items in one shot -- but within a
//     multi-target list, the next target's real value needs to be exactly
//     where the leftover container ended up sitting, so it was consumed as
//     the NEXT target's "value" instead (e.g. "m[\"k\"], arr[0] =
//     pair()" stored the whole map into arr[0], not pair()'s second return
//     value). Fixed by emitting an explicit Drop right after any compound
//     target's store, discarding the leftover container immediately
//     instead of letting it survive to interfere with the next target.
//
//  3. A third, related bug was found and fixed at the same time:
//     ByteCode.StoreCount() (internal/language/bytecode/bytecode.go),
//     used to detect how many targets a multi-target list actually has
//     (compileAssignment's multipleTargets flag, compileUnwrap's two-value
//     assertion detection, and compileParallelAssignment's RHS-count
//     validation all depend on it), only counted Store/CreateAndStore
//     instructions -- never StoreIndex. Once fix (1) above started
//     emitting StoreIndex correctly for compound targets, a list
//     containing only compound targets (no simple names at all) undercounted
//     as having 0 targets, breaking all three of those checks. Fixed by
//     counting StoreIndex alongside Store/CreateAndStore.

@test "datamodel: multi-target list with a map and array target (BUG-24)"
{
    m := map[string]int{}
    arr := []int{0, 0}

    func pair() (int, int) {
        return 5, 6
    }

    m["k"], arr[0] = pair()

    @assert m["k"] == 5
    @assert arr[0] == 6
}

@test "datamodel: multi-target list with a literal RHS list, not a call (BUG-24)"
{
    m := map[string]int{}
    arr := []int{0, 0}

    m["a"], arr[1] = 10, 20

    @assert m["a"] == 10
    @assert arr[1] == 20
}

@test "datamodel: multi-target list with := and compound targets (BUG-24)"
{
    func pair() (int, int) {
        return 7, 8
    }

    m := map[string]int{}
    arr := []int{0, 0}

    m["k"], arr[0] = pair()

    @assert m["k"] == 7
    @assert arr[0] == 8
}

@test "datamodel: multi-target list with struct field targets (BUG-24)"
{
    type point struct {
        x int
        y int
    }

    func pair() (int, int) {
        return 5, 6
    }

    p := point{}
    q := point{}

    p.x, q.y = pair()

    @assert p.x == 5
    @assert q.y == 6
}

@test "datamodel: multi-target list mixing simple and compound targets (BUG-24)"
{
    a := 0
    m := map[string]int{}
    arr := []int{0}

    a, m["x"], arr[0] = 1, 2, 3

    @assert a == 1
    @assert m["x"] == 2
    @assert arr[0] == 3
}

@test "datamodel: multi-target list with all-compound targets (BUG-24)"
{
    // This specific shape -- no simple names at all in the list -- is what
    // exposed the StoreCount() undercounting bug (root cause 3 above):
    // with zero Store/CreateAndStore instructions in the whole list, only
    // fixing root causes 1 and 2 would still have left this case broken.
    m1 := map[string]int{}
    m2 := map[string]int{}

    m1["p"], m2["q"] = 100, 200

    @assert m1["p"] == 100
    @assert m2["q"] == 200
}

@test "datamodel: multi-target list with a nested compound target (BUG-24)"
{
    type inner struct {
        v int
    }

    type outer struct {
        content inner
    }

    o := outer{content: inner{v: 0}}
    arr := []int{0}

    o.content.v, arr[0] = 11, 22

    @assert o.content.v == 11
    @assert arr[0] == 22
}

@test "datamodel: simple-target-only multi-assignment is unaffected (BUG-24 regression)"
{
    func pair() (int, int) {
        return 55, 66
    }

    a, b := pair()

    @assert a == 55
    @assert b == 66
}

@test "datamodel: single-target compound lvalue assignment is unaffected (BUG-24 regression)"
{
    m := map[string]int{}
    m["k"] = 42
    @assert m["k"] == 42

    arr := []int{0}
    arr[0] = 43
    @assert arr[0] == 43
}
