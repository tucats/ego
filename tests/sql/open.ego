// Tests for sql.Open() and sql.Database.Close().
//
// Each test is self-contained: it opens (and removes) its own database file so
// that failures in one test do not cascade.  The database files are created in
// /tmp/ using a UUID-derived name so parallel test runs do not collide.

@test "sql: Open() creates a sqlite3 connection"
{
    // Generate a unique temp file name for this test run.
    dbFile := "/tmp/ego_sql_open_" + uuid.New().Gibberish() + ".db"
    _ = os.Remove(dbFile)

    db, err := sql.Open("sqlite", dbFile)
    @assert err == nil
    @assert db != nil

    err = db.Close()
    @assert err == nil
    _ = os.Remove(dbFile)
}

@test "sql: Open() rejects an unsupported driver"
{
    _, err := sql.Open("mysql", "/tmp/ego_sql_dummy.db")
    @assert err != nil
}

@test "sql: Open() rejects credential database name"
{
    // The server's credential file (ego-system.db) is protected regardless
    // of the directory it's in, to prevent sandboxed code from reading auth data.
    _, err := sql.Open("sqlite", "/some/path/ego-system.db")
    @assert err != nil
}

@test "sql: Constr field holds the connection path"
{
    dbFile := "/tmp/ego_sql_constr_" + uuid.New().Gibberish() + ".db"
    _ = os.Remove(dbFile)

    db, err := sql.Open("sqlite", dbFile)
    @assert err == nil
    @assert db.Constr == dbFile

    _ = db.Close()
    _ = os.Remove(dbFile)
}

@test "sql: Close() sets Rowcount to -1"
{
    // After Close(), the runtime sets Rowcount to -1 as a sentinel that
    // signals the connection is gone.
    dbFile := "/tmp/ego_sql_close_" + uuid.New().Gibberish() + ".db"
    _ = os.Remove(dbFile)

    db, err := sql.Open("sqlite", dbFile)
    @assert err == nil

    err = db.Close()
    @assert err == nil
    @assert db.Rowcount == -1

    _ = os.Remove(dbFile)
}

@test "sql: second Close() returns an error"
{
    dbFile := "/tmp/ego_sql_dblclose_" + uuid.New().Gibberish() + ".db"
    _ = os.Remove(dbFile)

    db, err := sql.Open("sqlite", dbFile)
    @assert err == nil

    err = db.Close()
    @assert err == nil

    // The client field is nil after the first Close(); the second call must
    // return an error rather than panic or silently succeed.
    err = db.Close()
    @assert err != nil

    _ = os.Remove(dbFile)
}

@test "sql: AsStruct() affects QueryResult row shape"
{
    // AsStruct(true)  -> each row is a struct with named fields; StructMode == true
    // AsStruct(false) -> each row is an array of column values; StructMode == false
    dbFile := "/tmp/ego_sql_asstruct_" + uuid.New().Gibberish() + ".db"
    _ = os.Remove(dbFile)

    db, err := sql.Open("sqlite", dbFile)
    @assert err == nil

    _, err = db.Execute("CREATE TABLE t (id INTEGER, name TEXT)")
    @assert err == nil
    _, err = db.Execute("INSERT INTO t VALUES (1, 'hello')")
    @assert err == nil

    // Array mode (default).
    db.AsStruct(false)
    @assert db.StructMode == false
    rows, err := db.QueryResult("SELECT id, name FROM t")
    @assert err == nil
    @assert len(rows) == 1
    // In array mode rows[0] is an array; string(rows[0][1]) must work.
    @assert string(rows[0][1]) == "hello"

    // Struct mode: rows[0] is a struct with column-name fields.
    db.AsStruct(true)
    @assert db.StructMode == true
    rows2, err := db.QueryResult("SELECT id, name FROM t")
    @assert err == nil
    @assert len(rows2) == 1
    @assert string(rows2[0].name) == "hello"

    db.AsStruct(false)
    _ = db.Close()
    _ = os.Remove(dbFile)
}

@test "sql: AsStruct() returns (Database, error) for chaining"
{
    // Regression test: AsStruct() used to be declared with only a VoidType
    // return, and its one error path (client(s) failing, e.g. after Close())
    // returned a bare (nil, err) not wrapped in data.List. That combination
    // turned any error into an uncatchable-except-try/catch runtime abort
    // instead of a normal (value, error) result. AsStruct now returns
    // (sql.Database, error) like every other fallible method.
    dbFile := "/tmp/ego_sql_asstruct_err_" + uuid.New().Gibberish() + ".db"
    _ = os.Remove(dbFile)

    db, err := sql.Open("sqlite", dbFile)
    @assert err == nil

    v, err2 := db.AsStruct(true)
    @assert err2 == nil
    @assert v != nil

    _ = db.Close()

    _, err3 := db.AsStruct(true)
    @assert err3 != nil

    _ = os.Remove(dbFile)
}
