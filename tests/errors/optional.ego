// Tests for the optional operator: ?{expression} : {fallback}
//
// This is an Ego extension — NOT the ternary operator.
// Syntax:   result := ?expr : fallback
// Semantics: if evaluating expr produces a runtime error, use fallback instead.
//            If expr succeeds, use its value.
//
// The fallback can be any expression; its type does not need to match expr's type.
//
// Incorporated from tests/datamodel/optionals.ego.

@test "errors: optional, division by zero uses fallback"
{
    zero := 0

    a := ?(100/zero) : 99
    @assert a == 99

    // When the expression succeeds the real value is used.
    b := ?(100/5) : 99
    @assert b == 20
}

@test "errors: optional, missing field uses fallback"
{
    s := {name: "Tom", age: 35}

    // Field that does not exist → fallback
    missing := ?s.title : "anonymous"
    @assert missing == "anonymous"

    // Field that exists → real value
    present := ?s.name : "anonymous"
    @assert present == "Tom"
}

@test "errors: optional, out-of-bounds uses fallback"
{
    a := []int{1, 2, 3}

    // Valid index
    v := ?a[0] : -1
    @assert v == 1

    // Index beyond end of array → fallback
    oob := ?a[100] : -1
    @assert oob == -1
}

@test "errors: optional, type error uses fallback"
{
    // From tests/datamodel/optionals.ego: dividing a struct by an integer is
    // a type error; the optional operator catches it and returns the fallback.
    b := {name: "Tom", age: 35}
    result := ?(b/2) : true
    @assert result == true
}

@test "errors: optional, fallback type"
{
    zero := 0

    // Fallback is a string; result type is string when the error path is taken.
    s := ?(100/zero) : "fallback string"
    @assert s == "fallback string"
    @assert reflect.Type(s) == string

    // Fallback is bool
    b := ?(100/zero) : false
    @assert b == false
    @assert reflect.Type(b) == bool
}

@test "errors: optional, nested optionals"
{
    zero := 0

    // Inner optional produces 5 (its fallback), outer adds 10.
    result := (?(100/zero) : 5) + 10
    @assert result == 15
}

@test "errors: optional, map lookup on nil map"
{
    // Looking up a key in a nil map returns the zero value without error
    // in Go; Ego behaves the same way.  Verify that the success path works.
    m := map[string]int{"x": 1}
    v := ?m["x"] : -1
    @assert v == 1
}

@test "errors: BUG-35, optional operator escalates unlisted error to enclosing try"
{
    // The `?expr : fallback` optional operator (see internal/language/bytecode/try.go
    // OptionalCatchSet) is itself implemented as a try/catch whose catches list is
    // restricted to a small, specific set of errors (nil pointer, invalid type,
    // unknown member, divide-by-zero, array index, type mismatch, invalid value,
    // invalid integer/float).
    //
    // Regression for the BUG-35 fix: when the expression raises an error that is
    // NOT in that set (e.g. a user-raised @error), the optional operator's own
    // (selective) try/catch cannot handle it — but an enclosing try/catch further
    // out must still get a chance to catch it. Before the fix, handleCatch only
    // ever inspected the innermost try frame, so a non-matching selective catch
    // caused the error to be reported as uncaught even with a live outer catch-all
    // try available.
    func failer() int {
        @error "custom.failure"

        return -999
    }

    outerCaught := false
    result := 0

    try {
        result = ?failer() : -1
    } catch(e) {
        outerCaught = true
        @assert e.Is(errors.New("custom.failure"))
    }

    @assert outerCaught
    @assert result == 0   // assignment never completed; result keeps its initial value
}

@test "errors: BUG-35, optional operator nested inside a catch block"
{
    // Combines both aspects of the BUG-35 fix: an error is raised while a catch
    // block is executing (escalation past a spent frame), and the error comes
    // from a `?:` optional operator whose own selective catch set does not
    // include it (escalation past a live, non-matching frame). Both must
    // correctly unwind to the outermost catch-all try.
    func failer() int {
        @error "custom.failure"

        return -999
    }

    outerCaught := false

    try {
        try {
            x := 0
            _ = 5 / x
        } catch {
            _ = ?failer() : -1
        }
    } catch(e) {
        outerCaught = true
        @assert e.Is(errors.New("custom.failure"))
    }

    @assert outerCaught

    // Sanity: the ordinary (in-set) fallback path is unaffected by the fix.
    y := 0
    z := ?(15 / y) : -1
    @assert z == -1
}
