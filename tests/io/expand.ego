@test "io: io.Expand() single path name with no extension"
{
    here := profile.Get("ego.runtime.path")
    want := [filepath.Join(here, "main.go")]
    got := io.Expand(filepath.Join(here,"main.go"))
    @assert T.Equal(want, got, "single path name with no extension" )
}

@test "io: io.Expand() single path name with .go extension"
{
    here := profile.Get("ego.runtime.path")
    want := filepath.Join(here, "internal/cli/app/actions.go")
    got := io.Expand(here, ".go")
    found := ( index(got, want) >=0 )
    @assert T.Equal(found, true,  "single path name with .go extension")
}

@test "io: io.Expand() with single level deep directory"
{
    here := profile.Get("ego.runtime.path")
    want := filepath.Join(here, "tests/README.md")
    got := io.Expand(filepath.Join(here, "tests"))
    @assert T.True(len(got)>0, "did not return a list")
    @assert T.Equal(got[0], want, "single level deep directory, got " + string(got))
}

@test "io: io.Expand() returns a catchable error for a bad path"
{
    // Regression test: Expand() used to be declared with only a single
    // ([]string) return, so a failure could only be observed by an
    // uncaught, program-aborting runtime error. It now returns
    // ([]string, error) like io.Open()/io.ReadDir(), so the error is a
    // normal assignable value.
    fns, e := io.Expand("/no/such/path/ego-test-xyz")
    @assert e != nil
    @assert len(fns) == 0
}
