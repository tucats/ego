// Tests for value vs. pointer receiver semantics on a type defined in an
// imported package (tests/packages/employee.ego). funcs.ego already covers
// the basic pointer-receiver case (SetName); this file adds the value
// receiver case and confirms the two differ exactly as they do for locally
// defined types (see tests/functions/receivers.ego).

@test "packages: employee, pointer receiver mutates caller's struct"
import "tests/packages/employee"
{
    e := employee.Employee{Id: 1, Name: "Original"}
    e.SetName("Updated")

    @assert e.Name == "Updated"
}

@test "packages: employee, value receiver does not mutate caller's struct"
{
    e := employee.Employee{Id: 2, Name: "Original"}
    e.Rename("ShouldNotStick")

    @assert e.Name == "Original"
}

@test "packages: employee, pointer receiver via NewEmployee's *Employee"
{
    employee.ResetHeadCount()

    e := employee.NewEmployee("Carol")
    e.SetName("Caroline")

    @assert e.Name == "Caroline"

    employee.ResetHeadCount()
}
