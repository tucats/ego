@test "packages: uuid" {

	// Test of "Gibberish" function, which produces a string of lower-case
	// characters and digits representing the UUID value, which does not
	// contain the letters "o" or "l" or "i" to avoid confusion with digits 
	// 0 and 1.
	u := uuid.Parse("ab34d542-a437-408a-b0ca-38ea5d78696f")
	g := u.Gibberish()

	@assert g == "rm4szqj72tubkesqdukixgpyk"

	// Test the Nil() function, which returns a UUID with all zeros
	u = uuid.Nil()
	g = u.String()

	@assert g == "00000000-0000-0000-0000-000000000000"

	// Test the New() function, which returns a new UUID. Convert to a string,
	// and the re-parse the string to confirm it is the same UUID value.
	u = uuid.New()
	g = u.String()
	p := uuid.Parse(g)

	@assert u == p

}

// Regression test for BUG-40: uuid.Parse on invalid input must return a
// normal, catchable (nil, error) pair rather than aborting the program.
// Prior to the fix, this whole test file would abort with an uncatchable
// runtime error before ever reaching the @assert statements below.
@test "packages: uuid.Parse invalid input is catchable" {

	// The two-value form documented in docs/LANGUAGE.md: id is nil and err
	// describes the failure, with no program-terminating error.
	id, err := uuid.Parse("not-a-uuid")

	@assert id == nil
	@assert err != nil
	@assert err.Error() == "invalid UUID length: 10"
}

// Regression test: the zero value of a "var" declared uuid.UUID must be
// usable, matching Go's own zero value for uuid.UUID ([16]byte), which is
// the valid nil UUID. Before this was fixed, UUIDTypeDef had no registered
// constructor, so InstanceOf fell back to an empty struct with no native
// field at all, and every method call failed with "invalid field name for
// type: native value".
@test "packages: uuid zero value is a usable nil UUID" {
	var x uuid.UUID

	@assert x.String() == "00000000-0000-0000-0000-000000000000"
	@assert x == uuid.Nil()
}
