// Tests for defer interaction with named return values.

@test "defer: single named return modified by defer"
{
    func f() (x int) {
        x = 5
        defer func() { x = 42 }()
        return
    }

    v := f()
    @assert v == 42
}

@test "defer: two named returns modified by defers"
{
    func f() (a int, b int) {
        defer func() { a = 10 }()
        defer func() { b = 20 }()
    }

    x, y := f()
    @assert x == 10
    @assert y == 20
}

@test "defer: named returns with conditional defer"
{
    func safeDivide(a, b int) (result int, ok bool) {
        ok = true
        defer func() {
            if !ok {
                result = 0
            }
        }()

        if b == 0 {
            ok = false
            return
        }

        result = a / b
        return
    }

    r, ok := safeDivide(10, 2)
    @assert r == 5
    @assert ok == true

    r, ok = safeDivide(10, 0)
    @assert r == 0
    @assert ok == false
}
