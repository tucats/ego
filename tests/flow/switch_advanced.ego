// Advanced switch statement tests.
//
// Covers:
//   - Switch with an init assignment (Ego form: switch x := expr { ... })
//   - Semicolon-separated init form (Go form: switch x := f(); x { ... })
//   - Multiple fallthrough cases in a row
//   - Conditional (expression-less) switch with complex conditions
//   - Switch inside a loop with break
//   - Switch on a string value
//   - Multi-value case clause (case 1, 2, 3:)

@test "flow: switch with init assignment"
{
    // Ego supports switch x := expr { ... } where the initialization and the
    // switch value are the same expression. The variable x is in scope only
    // within the switch block.
    func status() int { return 2 }

    result := ""
    switch code := status() {
    case 1:
        result = "one"
    case 2:
        result = "two"
    case 3:
        result = "three"
    default:
        result = "other"
    }

    @assert result == "two"
}

@test "flow: switch with init case body scope"
{
    // The variable created by the init clause is visible inside each case body.
    func getCode() int { return 99 }

    seen := 0
    switch code := getCode() {
    case 99:
        seen = code
    }

    @assert seen == 99
}

@test "flow: chained fallthrough"
{
    // Fallthrough causes execution to continue into the next case body
    // unconditionally. Chaining two fallthrough statements should execute
    // three consecutive case bodies.
    log := ""
    switch 1 {
    case 1:
        log = log + "A"
        fallthrough
    case 2:
        log = log + "B"
        fallthrough
    case 3:
        log = log + "C"
    case 4:
        log = log + "D"
    }

    // case 1 matched, fell through 2, fell through 3; case 4 not reached.
    @assert log == "ABC"
}

@test "flow: fallthrough does not execute skipped cases"
{
    // Fallthrough only enters the immediately next case body, regardless of
    // whether the next case's expression would have matched the switch value.
    count := 0
    switch 5 {
    case 5:
        count++
        fallthrough
    case 99:
        // This body runs because of fallthrough, not because 5 == 99.
        count++
    case 6:
        count++
    }

    @assert count == 2
}

@test "flow: switch on string value"
{
    // Switch works on string values just like integers. Multi-value case clauses
    // allow grouping several values onto one branch (case "Sat", "Sun":).
    days := []string{"Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"}
    weekdays := 0
    weekends := 0

    for _, d := range days {
        switch d {
        case "Sat", "Sun":
            weekends++
        default:
            weekdays++
        }
    }

    @assert weekdays == 5
    @assert weekends == 2
}

@test "flow: switch case with multiple values"
{
    // A case clause may list multiple values separated by commas; the body runs
    // when the switch expression equals any one of them.
    matched := false
    x := 2
    switch x {
    case 1, 2, 3:
        matched = true
    case 4, 5:
        @fail "wrong branch"
    }
    @assert matched

    // A value outside all listed values falls through to default.
    matched = false
    x = 9
    switch x {
    case 1, 2, 3:
        @fail "wrong branch"
    default:
        matched = true
    }
    @assert matched
}

@test "flow: conditional switch, complex expressions"
{
    // Expression-less switch where each case is a boolean condition.
    // Tests that only the FIRST matching case runs (no implicit fallthrough).
    score := 73

    grade := ""
    switch {
    case score >= 90:
        grade = "A"
    case score >= 80:
        grade = "B"
    case score >= 70:
        grade = "C"
    case score >= 60:
        grade = "D"
    default:
        grade = "F"
    }

    @assert grade == "C"
}

@test "flow: switch without matching case or default"
{
    // If no case matches and there is no default clause, the switch is a no-op.
    executed := false
    x := 42
    switch x {
    case 1:
        executed = true
    case 2:
        executed = true
    }

    @assert !executed
}

@test "flow: switch inside a for loop"
{
    // Verifies that switch inside a loop works correctly across multiple iterations
    // and that each iteration evaluates the switch expression independently.
    result := ""
    for i := 0; i < 5; i++ {
        switch {
        case i == 0:
            result = result + "z"
        case i%2 == 0:
            result = result + "e"
        default:
            result = result + "o"
        }
    }

    // i=0 -> 'z', i=1 -> 'o', i=2 -> 'e', i=3 -> 'o', i=4 -> 'e'
    @assert result == "zoeoe"
}

@test "flow: switch on boolean expressions"
{
    // Switch can be used on boolean values.
    found := true
    switch found {
    case true:
        @assert found
    case false:
        @fail "Should not reach false branch"
    }
}

@test "flow: switch \";\"  form, same var as switch value"
{
    // Go-compatible: switch x := f(); x { ... }
    // The init variable is also used as the switch expression.
    func getCode() int { return 3 }

    result := ""
    switch code := getCode(); code {
    case 1:
        result = "one"
    case 2:
        result = "two"
    case 3:
        result = "three"
    default:
        result = "other"
    }

    @assert result == "three"
}

@test "flow: switch \";\"  form with boolean condition"
{
    // Go-compatible: switch x := f(); x > 0 { case true: ... }
    // The switch expression is a boolean derived from the init variable.
    func getValue() int { return 7 }

    label := ""
    switch n := getValue(); n > 0 {
    case true:
        label = "positive"
    case false:
        label = "non-positive"
    }

    @assert label == "positive"
}

@test "flow: switch \";\" init var visible in case body"
{
    // The init variable declared before the semicolon is in scope inside
    // each case body, not just in the switch expression.
    func fetchCode() int { return 42 }

    seen := 0
    switch code := fetchCode(); code {
    case 42:
        seen = code
    default:
        @fail "wrong branch"
    }

    @assert seen == 42
}

@test "flow: fallthrough into default clause (BUG-25)"
{
    // Regression test for BUG-25: "fallthrough" from a matched "case" into
    // the switch's "default" clause is legal, idiomatic Go and must run the
    // default body exactly once. Before the fix, this compiled to a branch
    // instruction targeting bytecode address 0, which sent execution back to
    // the start of the enclosing code and looped forever.
    fallLog := ""
    switch 2 {
    case 1:
        fallLog = fallLog + "one"
    case 2:
        fallLog = fallLog + "two"
        fallthrough
    default:
        fallLog = fallLog + "+default"
    }

    @assert fallLog == "two+default"
}

@test "flow: conditional switch fallthrough into default (BUG-25)"
{
    // Same regression as above, but for a conditional (expression-less)
    // switch. Fallthrough is compiled by the same shared code regardless of
    // whether the switch has a value or is condition-based, so both forms
    // need coverage.
    fallCount := 0
    switch {
    case fallCount < 0:
        fallCount = 100
    case fallCount == 0:
        fallCount++
        fallthrough
    default:
        fallCount++
    }

    @assert fallCount == 2
}

@test "flow: fallthrough into default runs exactly once (BUG-25)"
{
    // Uses a counter to prove the default body runs exactly once - not zero
    // times (default skipped) and not "many" times (the infinite-loop bug).
    fallRuns := 0
    switch 9 {
    case 9:
        fallthrough
    default:
        fallRuns++
    }

    @assert fallRuns == 1
}

@test "flow: fallthrough as final statement is a compile error (BUG-25)"
{
    // "fallthrough" used as the last statement of a switch's last clause,
    // with no case or default clause following it, must be rejected at
    // compile time - the same error real Go reports ("cannot fallthrough
    // final case in switch"). The @compile directive lets us compile this
    // broken fragment at runtime and catch the resulting error instead of
    // failing the whole test file. Before the fix, this compiled cleanly
    // into a branch to bytecode address 0, which looped forever at runtime.
    //
    // The broken switch is wrapped in its own function and compiled in
    // full-program mode (no "block" flag) rather than inline block mode;
    // block mode shares the outer compiler's scope-tracking flags, and on
    // a profile with "unused variable" errors enabled, that combination
    // flags "caught" below as unused even though it is both assigned and
    // read. Full-program mode compiles the broken code in a completely
    // separate sub-compiler, avoiding that interaction entirely.
    var caught bool

    @compile {
        func broken() {
            switch 1 {
            case 1:
                fallthrough
            }
        }
    } catch(e) {
        caught = true
        @assert e.Code() == "invalid.fallthrough"
    }

    @assert caught == true
}

@test "flow: fallthrough after an earlier default is still an error (BUG-25)"
{
    // A "default:" clause declared *before* the case that ends in
    // "fallthrough" does not count as "the next clause" - fallthrough only
    // targets the clause that immediately follows it in source order. Since
    // nothing follows this fallthrough, it must still be a compile error.
    var caught bool

    @compile {
        func broken() {
            switch 1 {
            default:
                // intentionally empty
            case 1:
                fallthrough
            }
        }
    } catch(e) {
        caught = true
        @assert e.Code() == "invalid.fallthrough"
    }

    @assert caught == true
}

@test "flow: switch break stays in switch (BUG-31)"
{
    // In Go (and every C-family language), a bare "break" inside a "switch"
    // exits only the switch - not any "for" loop the switch happens to be
    // sitting inside. Before the fix, Ego's "break" always targeted the
    // nearest enclosing "for" loop instead, so this loop would have stopped
    // dead after i==3 instead of running all five iterations.
    visited := ""

    for i := 0; i < 5; i++ {
        switch i {
        case 3:
            break
        }
        visited = visited + string(i)
    }

    @assert visited == "01234"
}

@test "flow: break in switch with no loop (BUG-31)"
{
    // A "switch" does not need to be inside a loop at all for "break" to be
    // legal inside one of its cases - it simply ends the switch early, the
    // same as falling off the end of the case body would. Before the fix
    // this was rejected as a compile-time error ("loop control statement
    // outside of for-loop") even though no loop is involved.
    x := 5
    reached := false

    switch x {
    case 5:
        break
    }

    reached = true

    @assert reached == true
}

@test "flow: continue in switch reaches loop (BUG-31)"
{
    // Unlike "break", Go has no notion of "continue the switch" - a bare
    // "continue" written inside a switch always continues the nearest
    // enclosing "for" loop. This must keep working once "switch" started
    // pushing its own entry onto the same break/continue tracking stack
    // that "for" loops use.
    visited := ""

    for i := 0; i < 5; i++ {
        switch i {
        case 2:
            continue
        }
        visited = visited + string(i)
    }

    @assert visited == "0134"
}

@test "flow: labeled break past switch (BUG-31)"
{
    // A labeled break (e.g. "break outer") must still find and exit the
    // labeled "for" loop even when written inside a "switch" nested in that
    // loop - the switch's own tracking entry must not get in the way of the
    // label lookup.
    visited := ""

outer:
    for i := 0; i < 5; i++ {
        switch i {
        case 2:
            break outer
        }
        visited = visited + string(i)
    }

    @assert visited == "01"
}

@test "flow: nested switch break is inner only (BUG-31)"
{
    // When a switch is nested directly inside another switch (no loop
    // involved at all), an unlabeled "break" in the inner switch's case
    // body must exit only that inner switch, leaving the outer switch's
    // remaining statements to run normally.
    reachedAfterInner := false
    reachedAfterOuter := false

    switch 1 {
    case 1:
        switch true {
        case true:
            break
        }
        reachedAfterInner = true
    }

    reachedAfterOuter = true

    @assert reachedAfterInner == true
    @assert reachedAfterOuter == true
}

@test "flow: continue in bare switch is error (BUG-31)"
{
    // A bare "continue" with no enclosing "for" loop at all is still a
    // compile-time error, exactly as in real Go - BUG-31 only changed what
    // "break" is allowed to target, not "continue".
    var caught bool

    @compile {
        func broken() {
            switch 1 {
            case 1:
                continue
            }
        }
    } catch(e) {
        caught = true
        @assert e.Code() == "loop.control"
    }

    @assert caught == true
}
