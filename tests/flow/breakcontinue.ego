// Tests for break and continue statements in various loop forms.
//
// Covers:
//   - break in a for-range loop
//   - continue in a for-range loop
//   - break in a C-style index for-loop
//   - continue in a C-style index for-loop
//   - break in a condition-only (while-style) for-loop
//   - continue in a condition-only (while-style) for-loop

@test "flow: break and continue in range loop"
{
    // Accumulate the sum of indices 0..8, skipping index 3 (continue) and
    // stopping before index 9 (break). Result: 0+1+2 + 4+5+6+7+8 = 33.
    x := [1, 5, 3, 6, 9, 10, 2, 8, 4, 7]
    t := 0
    for i := range x {
        if i == 3 {
            continue
        }
        if i == 9 {
            break
        }
        t = t + i
    }

    @assert T.Equal(t, 33)
}

@test "flow: break and continue in C-style for-loop"
{
    // Run i from 1..9. Skip i==3 (continue), stop before i==7 (break).
    // Accumulated: 1+2 + 4+5+6 = 18.
    sum := 0
    for i := 1; i < 10; i++ {
        if i == 3 {
            continue
        }
        if i == 7 {
            break
        }
        sum += i
    }

    @assert T.Equal(sum, 18)
}

@test "flow: break and continue in condition for-loop"
{
    // While-style loop. Skip even values (continue), stop when n >= 11 (break).
    // Odd values accumulated: 1+3+5+7+9 = 25; loop exits when n reaches 11.
    n := 1
    sum := 0
    for n <= 20 {
        if n%2 == 0 {
            n++
            continue
        }
        if n >= 11 {
            break
        }
        sum += n
        n++
    }

    @assert T.Equal(sum, 25)
}
