// Regression tests for compile-time slot-based local variable access
// (docs/SLOTS.md). These exercise the slot machinery through ordinary Ego
// programs; they must produce identical results with slots on (the default) and
// off (ego.compiler.registers=false), which the full-suite differential run checks.

@test "slots: no cross-call bleed between activations"
{
    // Each call gets its own slot bank; distinct arguments must not leak
    // between activations of the same function.
    func acc(base int) int {
        total := base
        for i := 0; i < 3; i++ {
            step := i + 1
            total = total + step
        }
        return total
    }

    @assert acc(0) == 6
    @assert acc(100) == 106
    @assert acc(0) == 6
}

@test "slots: parameter reads and a body local shadowing a parameter"
{
    // Parameters are slotted (Phase 2); a body ":=" of the same name must
    // shadow the parameter within its block and revert afterward.
    func f(x int, y int) int {
        sum := x + y
        {
            x := x * 10
            sum = sum + x
        }
        // x is the parameter again here.
        return sum*100 + x
    }

    // f(2,3): sum=5; inner x=20 -> sum=25; return 25*100 + 2 = 2502
    @assert f(2, 3) == 2502
}

@test "slots: struct parameter is copied, not aliased"
{
    type box struct {
        v int
    }

    func mutate(b box) int {
        b.v = 999
        return b.v
    }

    original := box{v: 7}
    inside := mutate(original)

    // The parameter copy was mutated; the caller's struct is untouched.
    @assert inside == 999
    @assert original.v == 7
}

@test "slots: nested block shadowing reads outer binding"
{
    func shadow() int {
        x := 10
        y := 0
        {
            x := x + 5
            y = x
        }
        // The inner x (15) is gone; the outer x is still 10.
        return x*100 + y
    }

    @assert shadow() == 1015
}

@test "slots: self-referential shadow in a deeper scope"
{
    func f() int {
        n := 1
        {
            n := n + 1
            {
                n := n + 1
                @assert n == 3
            }
            @assert n == 2
        }
        return n
    }

    @assert f() == 1
}

@test "slots: address-of a slotted local"
{
    func viaPointer() int {
        v := 5
        p := &v
        *p = 42
        return v
    }

    @assert viaPointer() == 42
}

@test "slots: iteration counter and body temps are slotted"
{
    func sumSquares(n int) int {
        total := 0
        for i := 0; i < n; i++ {
            sq := i * i
            total = total + sq
        }
        return total
    }

    @assert sumSquares(4) == 14 // 0 + 1 + 4 + 9
}

@test "slots: compound assignment and increment on slotted locals"
{
    func counter() int {
        c := 0
        c += 5
        c++
        c--
        c = c * 2
        return c
    }

    @assert counter() == 10
}

@test "slots: range variables remain correct (name-based)"
{
    func joinInts(parts []int) int {
        sum := 0
        for i, p := range parts {
            if i > 0 {
                sum = sum + 1000
            }
            sum = sum + p
        }
        return sum
    }

    @assert joinInts([]int{1, 2, 3}) == 2006 // 1 + (1000+2) + (1000+3)
}

@test "slots: method with slotted params and body locals"
{
    // A method is slot-eligible: its parameter and body locals are slotted
    // while the receiver stays name-based. Called repeatedly, activations must
    // not bleed, and receiver mutation must persist.
    type acc struct {
        total int
    }

    func (a *acc) add(n int) int {
        sum := 0
        for i := 0; i < n; i++ {
            sum = sum + i
        }
        a.total = a.total + sum

        return a.total
    }

    object := acc{total: 10}

    // add(4): sum = 0+1+2+3 = 6; total = 16, then 22.
    @assert object.add(4) == 16
    @assert object.add(4) == 22
}

@test "slots: value receiver is copied, pointer receiver mutates"
{
    // The receiver is slotted (Phase 2). A value receiver must give the method
    // its own copy (mutations do not escape); a pointer receiver must mutate
    // the caller's value.
    type box struct {
        v int
    }

    func (b box) tryMutate(delta int) int {
        b.v = b.v + delta

        return b.v
    }

    func (b *box) grow(delta int) int {
        b.v = b.v + delta

        return b.v
    }

    x := box{v: 5}

    @assert x.tryMutate(10) == 15 // local copy
    @assert x.v == 5              // caller unchanged
    @assert x.grow(10) == 15
    @assert x.v == 15             // caller changed
}

@test "slots: recursion gives each activation fresh slots"
{
    func fib(n int) int {
        if n < 2 {
            return n
        }
        a := fib(n - 1)
        b := fib(n - 2)
        return a + b
    }

    @assert fib(10) == 55
}

@test "slots: named return variables (bare, accumulated, explicit)"
{
    // Named returns are slotted in an eligible function (no defer/closure).
    func divmod(a int, b int) (q int, r int) {
        q = a / b
        r = a - q*b

        return
    }

    func accumulate(n int) (total int) {
        for i := 0; i < n; i++ {
            total = total + i
        }

        return
    }

    func explicit(n int) (out int, ok bool) {
        if n > 0 {
            return n * 2, true
        }

        return 0, false
    }

    q, r := divmod(17, 5)
    @assert q == 3
    @assert r == 2
    @assert accumulate(5) == 10

    x, present := explicit(4)
    @assert x == 8
    @assert present

    y, absent := explicit(-1)
    @assert y == 0
    @assert !absent
}

@test "slots: named returns still work with a deferred recover (name-based)"
{
    // A function with a defer is NOT slot-eligible, so its named returns stay
    // name-based; a deferred recover must still read and modify them.
    func guarded(fail bool) (result int, msg string) {
        defer func() {
            if r := recover(); r != nil {
                result = -1
                msg = "caught"
            }
        }()

        if fail {
            panic("boom")
        }

        result = 42
        msg = "ok"

        return
    }

    r1, m1 := guarded(false)
    @assert r1 == 42
    @assert T.Equal(m1, "ok")

    r2, m2 := guarded(true)
    @assert r2 == -1
    @assert T.Equal(m2, "caught")
}

@test "slots: closure-containing function falls back correctly"
{
    // This function contains a capturing closure, so it is NOT slot-eligible
    // and uses the name-based path. It must still work identically.
    func makeAdder(base int) func(int) int {
        return func(x int) int {
            return base + x
        }
    }

    add10 := makeAdder(10)
    @assert add10(5) == 15
    @assert add10(0) == 10
}

@test "slots: slotted locals are visible to introspection by name"
{
    // util.Symbols() must see slotted locals by name, exactly as it sees
    // name-based ones (docs/SLOTS.md Q3 introspection). This is what the
    // debugger's "show symbols" and error formatting rely on.
    func introspect() bool {
        total := 41
        factor := 1
        total = total + factor
        syms := util.Symbols()
        hasTotal := strings.Contains(syms, "total")
        hasFactor := strings.Contains(syms, "factor")

        return hasTotal && hasFactor
    }

    @assert introspect()
}

@test "slots: struct value copy semantics preserved for slotted locals"
{
    type point struct {
        x int
        y int
    }

    func copies() int {
        a := point{x: 1, y: 2}
        b := a
        b.x = 99
        // a must be unaffected (struct value copy on ":=").
        return a.x*100 + b.x
    }

    @assert copies() == 199
}
