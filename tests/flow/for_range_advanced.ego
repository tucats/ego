// Advanced for-range tests covering edge cases not addressed in forrange.ego.
//
// Covers:
//   - Range over empty array, map, and string (zero iterations)
//   - Range with blank index variable (_ for index)
//   - Range over a typed slice
//   - Array element mutation inside a range loop (matches Go semantics)

@test "flow: range empty array yields no iterations"
{
    a := []int{}
    count := 0
    for i, _ := range a {
        count++
        _ = i
    }

    @assert count == 0
}

@test "flow: range empty map yields no iterations"
{
    m := map[string]int{}
    count := 0
    for k, v := range m {
        count++
        _ = k
        _ = v
    }

    @assert count == 0
}

@test "flow: range empty string yields no iterations"
{
    s := ""
    count := 0
    for _, ch := range s {
        count++
        _ = ch
    }

    @assert count == 0
}

@test "flow: range with blank index variable"
{
    // Using _ for the index variable discards the positional index; only
    // the element value is captured in the second variable.
    a := []int{10, 20, 30}
    sum := 0
    for _, v := range a {
        sum += v
    }

    @assert sum == 60
}

@test "flow: range over typed string slice"
{
    a := []string{"hello", " ", "world"}
    result := ""
    for _, s := range a {
        result = result + s
    }

    @assert result == "hello world"
}

@test "flow: range idx, direct idx loop, same result"
{
    // Verifies that iterating a typed array via range gives the same elements
    // as direct index access via a C-style loop.
    a := []int{5, 10, 15, 20, 25}

    range_sum := 0
    for _, v := range a {
        range_sum += v
    }

    index_sum := 0
    for i := 0; i < len(a); i++ {
        index_sum += a[i]
    }

    @assert range_sum == index_sum
}

@test "flow: range over array allows element mutation"
{
    // In Go and Ego, writing to a[i] inside a for-range body is legal and
    // modifies the original array in place. This matches Go slice semantics:
    // the range captures the array length at start but reads elements live.
    a := []int{1, 2, 3}
    for i, _ := range a {
        a[i] = a[i] * 10
    }

    @assert a[0] == 10
    @assert a[1] == 20
    @assert a[2] == 30
}

@test "flow: range mutation, direct index, same result"
{
    // Both range-based and index-based loops can mutate array elements.
    a := []int{1, 2, 3}
    b := []int{1, 2, 3}

    for i, _ := range a {
        a[i] *= 5
    }

    for i := 0; i < len(b); i++ {
        b[i] *= 5
    }

    @assert a[0] == b[0]
    @assert a[1] == b[1]
    @assert a[2] == b[2]
}
