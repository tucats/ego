@test "math: absolute value (abs, fabs)"

{
    // Abs
    @assert math.Abs(0.0)   == 0.0
    @assert math.Abs(3.0)   == 3.0
    @assert math.Abs(-3.0)  == 3.0
    @assert math.Abs(-5.0)  == 5.0
    @assert math.Abs(-1.54) == 1.54
    @assert math.Abs(1.54)  == 1.54
    @assert math.Abs(-100.0) >= 0.0
    @assert math.Abs(0.0001) > 0.0
}

@test "math: modulo and remainder (mod, remainder)"

{
    func near(a, b float64) bool {
        return math.Abs(a-b) < 1e-9
    }

    // Mod(x, y) returns x - Trunc(x/y)*y.
    // The sign of the result matches the sign of x (the dividend).
    @assert math.Mod(0.0,   3.0)  == 0.0
    @assert math.Mod(10.0,  3.0)  == 1.0
    @assert math.Mod(9.0,   3.0)  == 0.0
    @assert math.Mod(7.0,   2.0)  == 1.0
    @assert math.Mod(-10.0, 3.0)  == -1.0
    @assert math.Mod(10.0,  -3.0) == 1.0
    @assert near(math.Mod(5.5, 1.5), 1.0)

    // Mod identity: x == y*Trunc(x/y) + Mod(x, y)
    x := 17.5
    y := 4.0
    @assert near(x, y*math.Trunc(x/y) + math.Mod(x, y))

    // Remainder(x, y) uses IEEE 754 half-remainder semantics:
    //   result = x - y * RoundToEven(x/y)
    // The result always satisfies |result| <= |y|/2.
    @assert math.Remainder(0.0,   3.0) == 0.0
    @assert math.Remainder(1.0,   3.0) == 1.0
    @assert math.Remainder(9.0,   3.0) == 0.0
    @assert math.Remainder(10.0,  3.0) == 1.0
    @assert math.Remainder(-10.0, 3.0) == -1.0
    @assert math.Remainder(8.0,   3.0) == -1.0
    @assert math.Remainder(-8.0,  3.0) == 1.0
    @assert math.Remainder(7.0,   4.0) == -1.0
    @assert near(math.Remainder(5.5, 1.5), -0.5)

    // Remainder and Mod differ when the quotient is nearer to the next
    // integer than to the truncated one.  Canonical examples:
    //   Remainder(8,3) rounds 8/3=2.667 to 3 → 8-9 = -1
    //   Mod(8,3)       truncates 8/3 to 2    → 8-6 =  2
    @assert math.Remainder(8.0, 3.0) != math.Mod(8.0, 3.0)
    @assert math.Remainder(7.0, 4.0) != math.Mod(7.0, 4.0)
    @assert near(math.Remainder(5.5, 1.5), -0.5)
    @assert near(math.Mod(5.5, 1.5), 1.0)
}
