// Test new @compile directive, which allows capture of
// compile errors at runtime. Note that some of these 
// tests use the unknown=true flag to ensure that compilation
// unit being tests triggers an unknown variable error from
// the compiler, regardless of the user's current configuration
// settings.

@test "directives: @compile block with no error"
{
    x := 0
    @compile block {
        x = 33
    } catch(e) {
        @assert e.Error() != ""
    }

    @assert x == 33
}


@test "directives: @compile block with error"
{
    @compile block {
        fmt.Println(a b)
    } catch(e) {
        @assert e.Code() == "list"
    }
}


@test "directives: @compile code with no error"
{
    var failed bool 

    @compile {
        func foo() {
            x := 33
            fmt.Println(x)
        }
    } catch(e) {
        failed = true
        @assert e.Error() != ""
    }

    @assert failed == false
}


@test "directives: @compile code with error"
{
    var failed bool

    @compile unknown=true {
        func foo() {
            x := bob
            fmt.Println(x)
        }
    } catch(e) {
        failed = true
        @assert e.Code() == "symbol.not.found"
        @assert e.Unwrap() == "bob"
    }

    @assert failed == true
}


@test "directives: @compile exports a declared function to the enclosing scope"
{
    // A function declared in a @compile { ... } block (full-program mode)
    // must be callable from code that appears after the @compile statement
    // in the same test. Before this fix, the outer compiler's static-analysis
    // pass rejected the reference with "unknown symbol" because it didn't
    // know the @compile block would produce that name.
    var compileFailed bool

    @compile {
        import "strings"
        func lower(s string) string {
            return strings.ToLower(s)
        }
    } catch(e) {
        compileFailed = true
        @assert e.Error() != ""
    }

    @assert compileFailed == false
    @assert lower("ABC") == "abc"
}


@test "directives: @compile compile error is still caught after the export fix"
{
    // Regression guard: adding compile-time export must not suppress the
    // error path. A compile error inside a @compile { ... } block must
    // still land in catch(e) rather than silently passing.
    var compileFailed bool

    @compile unknown=true {
        func broken() {
            _ = nosuchname
        }
    } catch(e) {
        compileFailed = true
        @assert e.Code() == "symbol.not.found"
    }

    @assert compileFailed == true
}


@test "directives: @compile block nested if (BUG-39)"
{
    // BUG-39: the token collector that finds the end of an "@compile block
    // { ... }" directive counted braces starting at 1 (for the directive's
    // own opening brace) and incorrectly stopped as soon as the count
    // returned to 1 -- which happens the moment ANY nested brace pair (here,
    // the "if" body) closes, not just at the directive's own matching "}".
    // That silently truncated the block, leaving the trailing "catch(e)"
    // clause below to be parsed as an unexpected token, so this whole test
    // file failed to compile at all before the fix.
    //
    // x is declared inside the block (as in the original bug reproducer)
    // rather than mutated from an outer variable: block-mode @compile
    // content compiles in an isolated sub-compiler that does not share the
    // outer scope's static variable knowledge, so assigning to an outer
    // name only through a nested "if" trips an unrelated "unused variable"
    // quirk in that sub-compiler's own scope tracking -- not what this test
    // is checking.
    var reachedEnd bool

    @compile block {
        x := 1
        if true {
            x = 2
        }
        @assert x== 2
    } catch(e) {
        @fail "unexpected compile error: " + e.Error()
    }

    // Code lexically after the @compile...catch construct must still run.
    reachedEnd = true
    @assert reachedEnd
}


@test "directives: @compile unused=false suppresses unused variable error (BUG-54)"
{
    // BUG-54: the "unused=false" flag on @compile is documented to disable
    // unused-variable checking for the compiled block, but the compile
    // error was reported regardless. Root cause: the compiled block's own
    // top-level scope is never popped via PopSymbolScope (which does honor
    // the unused-vars flag) -- it is only swept up, unconditionally, by
    // Compiler.Errors() when the sub-compiler closes.
    var caught bool

    @compile block unused=false {
        neverUsed := 42
    } catch {
        caught = true
    }

    @assert caught == false
}


@test "directives: @compile unused=true still reports unused variable error"
{
    // Companion to the BUG-54 test above: confirms the fix didn't disable
    // unused-variable detection altogether, only honored unused=false.
    var caught bool

    @compile block unused=true {
        neverUsed := 42
    } catch(e) {
        caught = true
        @assert e.Code() == "var.unused"
    }

    @assert caught == true
}


@test "directives: @compile two funcs (BUG-39)"
{
    // BUG-39 (full-program / non-"block" form): the same brace-counting bug
    // dropped exactly one closing brace from the collected tokens, which was
    // invisibly patched by a compensating append -- but that compensation
    // only ever covers ONE dropped brace. A second top-level braced
    // construct (a second function declaration here) exposed the bug for
    // the full-program form too.
    var compileFailed bool

    @compile {
        func addOne(n int) int {
            return n + 1
        }
        func addTwo(n int) int {
            return n + 2
        }
    } catch {
        compileFailed = true
    }

    @assert compileFailed == false
    @assert addOne(addTwo(1)) == 4
}
