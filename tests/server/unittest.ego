@test "server: unittest - media negotiation returns JSON when requested"
{
    if !ServerAvailable {
        return
    }

    conn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("application/json")

    r, err := conn.Get("services/unit-test/media")
    @assert err == nil
    @assert r.format == "json"
}

@test "server: unittest - media negotiation returns text when requested"
{
    if !ServerAvailable {
        return
    }

    conn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("text/plain")

    r, err := conn.Get("services/unit-test/media")
    @assert err == nil
    @assert index(string(r), "format=text") >= 0
}

@test "server: unittest - media negotiation rejects an unsupported Accept type"
{
    if !ServerAvailable {
        return
    }

    conn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("application/xml")

    _, _ = conn.Get("services/unit-test/media")
    @assert conn.Status == 400
}

@test "server: unittest - protected endpoint rejects unauthenticated requests"
{
    if !ServerAvailable {
        return
    }

    conn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("application/json")

    _, _ = conn.Get("services/unit-test/protected")
    @assert conn.Status == 401 || conn.Status == 403
}

@test "server: unittest - protected endpoint accepts an authenticated request"
{
    if !ServerAvailable {
        return
    }

    logonConn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("application/json")
    credentials := { username: "admin", password: "password" }
    logon := logonConn.Post("services/admin/logon/", credentials)
    logonConn.Close()

    conn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("application/json").Token(logon.token)

    r, err := conn.Get("services/unit-test/protected")
    @assert err == nil
    @assert r.username == "admin"
}

@test "server: unittest - status endpoint returns the requested status code"
{
    if !ServerAvailable {
        return
    }

    conn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("application/json")

    _, err := conn.Get("services/unit-test/status/200")
    @assert err == nil
    @assert conn.Status == 200

    _, _ = conn.Get("services/unit-test/status/404")
    @assert conn.Status == 404

    _, _ = conn.Get("services/unit-test/status/500")
    @assert conn.Status == 500
}
