@test "server: unittest - verify server heartbeat"
{
    @global ServerAddr os.Hostname() + ".local"
    @global ServerAvailable true

    conn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("application/json")

    _, err := conn.Get("admin/heartbeat")
    if err != nil {
        fmt.Println("Unit-test endpoint tests will not be run, server unavailable:", err)
        ServerAvailable = false

        return
    }

    conn.Close()
}

@test "server: unittest - echo GET reflects method and query parameters"
{
    if !ServerAvailable {
        return
    }

    conn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("application/json")

    r, err := conn.Get("services/unit-test/echo?name=foo&count=5")
    @assert err == nil
    @assert r.method == "GET"
    @assert r.parameters.name[0] == "foo"
    @assert r.parameters.count[0] == "5"
}

@test "server: unittest - echo GET rejects an unparsable count parameter"
{
    if !ServerAvailable {
        return
    }

    conn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("application/json")

    // A well-formed JSON error body (status >= 400 that still starts with "{")
    // is not itself a client-side error -- Get() only returns a non-nil error
    // for a transport-level failure. Check conn.Status for the rejection.
    _, _ = conn.Get("services/unit-test/echo?count=notanumber")
    @assert conn.Status == 400
}

@test "server: unittest - echo PUT reflects method and body"
{
    if !ServerAvailable {
        return
    }

    conn := rest.New("").Base("https://" + ServerAddr + ":443").Verify(false).Media("application/json")

    r, err := conn.Put("services/unit-test/echo", { hello: "world" })
    @assert err == nil
    @assert r.method == "PUT"
    @assert index(r.body, "\"hello\":\"world\"") >= 0
}

